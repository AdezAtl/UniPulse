---
import AppLayout from "../layouts/AppLayout.astro";
import { getResources } from "../lib/db";
import { formatDate } from "../lib/utils";
const user = Astro.locals.user!;
const resources = getResources();
---

<AppLayout activeNav="resources" user={user} title="Resources · UniPulse">
  <div class="page-header">
    <h1 class="page-title">Resources</h1>
    <button id="open-upload" class="btn btn-primary btn-sm">+ Upload</button>
  </div>

  <div id="upload-modal" class="modal-overlay" hidden>
    <div class="modal-box">
      <div
        style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem"
      >
        <h3 style="font-size:.9375rem;font-weight:600">Upload Resource</h3>
        <button id="upload-close" class="btn btn-ghost btn-xs">✕</button>
      </div>
      <form
        id="upload-form"
        style="display:flex;flex-direction:column;gap:.875rem"
      >
        <div>
          <label class="label">Title *</label>
          <input
            name="title"
            type="text"
            required
            maxlength="120"
            class="input"
            placeholder="e.g. 2024 Thermodynamics Past Questions"
          />
        </div>
        <div>
          <label class="label">Description</label>
          <textarea
            name="description"
            rows="2"
            maxlength="300"
            class="input"
            style="resize:none"
            placeholder="Brief description…"></textarea>
        </div>
        <div>
          <label class="label">Link URL</label>
          <input
            name="link_url"
            type="url"
            class="input"
            placeholder="https://…"
          />
        </div>
        <div id="upload-error" class="alert alert-danger" hidden></div>
        <div
          style="display:flex;justify-content:flex-end;gap:.5rem;margin-top:.25rem"
        >
          <button
            type="button"
            id="upload-cancel"
            class="btn btn-secondary btn-sm">Cancel</button
          >
          <button type="submit" id="upload-btn" class="btn btn-primary btn-sm"
            >Upload</button
          >
        </div>
      </form>
    </div>
  </div>

  <div class="resources-list">
    {
      resources.length === 0 ? (
        <div class="empty-state">
          <>
            <p class="empty-icon">◉</p>
            <p class="empty-title">No resources yet</p>
            <p class="empty-sub">Upload PDFs, links, or study materials.</p>
          </>
        </div>
      ) : (
        resources.map((r) => (
          <div class="resource-card card">
            <div style="display:flex;gap:.75rem;align-items:flex-start">
              <span style="font-size:1.25rem;flex-shrink:0;margin-top:2px">
                {r.file_url ? "📄" : "🔗"}
              </span>
              <div style="flex:1;min-width:0">
                <h3 style="font-size:.9375rem;font-weight:500;color:var(--text);margin-bottom:.25rem">
                  {r.title}
                </h3>
                {r.description && (
                  <p
                    class="muted"
                    style="font-size:.8125rem;margin-bottom:.375rem"
                  >
                    {r.description}
                  </p>
                )}
                <div style="display:flex;align-items:center;flex-wrap:wrap;gap:.375rem">
                  <span class="hint">@{r.uploader_username ?? "unknown"}</span>
                  <span class="hint">·</span>
                  <span class="hint">{formatDate(r.created_at)}</span>
                  {r.link_url && (
                    <a
                      href={r.link_url}
                      target="_blank"
                      rel="noopener"
                      style="font-size:.8125rem;font-weight:500;color:var(--accent);text-decoration:none;margin-left:.25rem"
                    >
                      Open link →
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))
      )
    }
  </div>
</AppLayout>

<script>
  const modal = document.getElementById("upload-modal") as HTMLElement;
  document
    .getElementById("open-upload")
    ?.addEventListener("click", () => (modal.hidden = false));
  document
    .getElementById("upload-close")
    ?.addEventListener("click", () => (modal.hidden = true));
  document
    .getElementById("upload-cancel")
    ?.addEventListener("click", () => (modal.hidden = true));

  document
    .getElementById("upload-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = document.getElementById("upload-btn") as HTMLButtonElement;
      const errBox = document.getElementById("upload-error") as HTMLElement;
      const get = (n: string) =>
        (form.elements.namedItem(n) as HTMLInputElement)?.value.trim();

      errBox.hidden = true;
      btn.disabled = true;
      btn.textContent = "Uploading…";

      const res = await fetch("/api/resources", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          title: get("title"),
          description: get("description") || undefined,
          link_url: get("link_url") || undefined,
        }),
      });

      if (res.ok) {
        window.location.reload();
      } else {
        const { error } = await res.json();
        errBox.textContent = error;
        errBox.hidden = false;
        btn.disabled = false;
        btn.textContent = "Upload";
      }
    });
</script>

<style>
  .resources-list {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .resource-card {
    padding: 1rem 1.25rem;
  }
</style>
