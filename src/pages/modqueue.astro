---
import AppLayout from "../layouts/AppLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getAllPostsAdmin, getLikedPostIds } from "../lib/db";

const user = Astro.locals.user!;
if (user.role !== 'admin') {
  return Astro.redirect('/feed');
}

const posts = getAllPostsAdmin().filter(p => p.is_flagged);
const likedIds = getLikedPostIds(user.id);
const likedSet = new Set(likedIds);
---

<AppLayout activeNav="modqueue" user={user} title="Mod Queue · UniPulse">
  <div class="page-header" style="margin-bottom: 1rem; border-bottom: none;"><h1 class="page-title">Moderation Queue</h1></div>
  
  <div class="feed-posts">
    {
      !posts || posts.length === 0 ? (
        <div class="empty-state">
          <p class="empty-icon">🛡️</p>
          <p class="empty-title">Queue is clean!</p>
          <p class="empty-sub">No flagged posts to review.</p>
        </div>
      ) : (
        posts.map((post) => (
          <PostCard
            post={post}
            isLiked={likedSet.has(post.id)}
            isAdmin={true}
            currentUserId={user.id}
          />
        ))
      )
    }
  </div>
</AppLayout>
