---
import AppLayout from "../layouts/AppLayout.astro";

const user = Astro.locals.user!;

const DEPARTMENTS = [
  "Computer Science",
  "Engineering",
  "Medicine",
  "Law",
  "Business",
  "Arts & Humanities",
  "Natural Sciences",
  "Social Sciences",
  "Education",
  "Other",
];
const LEVELS = [
  "100 Level",
  "200 Level",
  "300 Level",
  "400 Level",
  "500 Level",
  "Postgraduate",
];

const success = Astro.url.searchParams.get("success");
const errMsg = Astro.url.searchParams.get("error");
---

<AppLayout
  activeNav="settings"
  user={user}
  title="Settings · UniPulse"
  showRightPanel={false}
>
  <div class="page-header">
    <h1 class="page-title">Settings</h1>
  </div>

  <div class="settings-layout">
    <!-- Sidebar nav -->
    <nav class="settings-nav">
      <a href="#profile" class="settings-link active" data-section="profile"
        >Profile</a
      >
      <a href="#account" class="settings-link" data-section="account">Account</a
      >
      <a href="#identity" class="settings-link" data-section="identity"
        >Identity</a
      >
    </nav>

    <div class="settings-content">
      {
        success === "profile" && (
          <div class="alert alert-success" style="margin-bottom:1.5rem">
            Profile updated successfully.
          </div>
        )
      }
      {
        success === "password" && (
          <div class="alert alert-success" style="margin-bottom:1.5rem">
            Password changed successfully.
          </div>
        )
      }
      {
        errMsg && (
          <div class="alert alert-danger" style="margin-bottom:1.5rem">
            {errMsg}
          </div>
        )
      }

      <!-- ── Profile ──────────────────────────────────────────────────────── -->
      <section class="settings-section" id="profile">
        <div class="section-header">
          <h2 class="section-title">Profile</h2>
          <p class="muted">Your public-facing information on UniPulse.</p>
        </div>

        <div class="avatar-row">
          <div
            class="avatar"
            style="width:64px;height:64px;font-size:1.5rem;font-weight:600;flex-shrink:0"
          >
            {
              user.avatar_url ? (
                <img
                  id="avatar-preview-img"
                  src={user.avatar_url}
                  alt=""
                  style="width:100%;height:100%;object-fit:cover;border-radius:50%"
                />
              ) : (
                <>
                  <img
                    id="avatar-preview-img"
                    src=""
                    alt=""
                    style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:none"
                  />
                  <span id="avatar-preview-initial">{user.username.charAt(0).toUpperCase()}</span>
                </>
              )
            }
          </div>
          <div>
            <p style="font-size:.875rem;font-weight:500;color:var(--text)">
              @{user.username}
            </p>
            <p class="hint">{user.pulse_id}</p>
            <div style="margin-top:.5rem; display:flex; gap:.5rem; align-items:center;">
              <input type="file" id="avatar-upload" accept="image/*" hidden />
              <button type="button" id="upload-avatar-btn" class="btn btn-secondary btn-xs">Upload Image</button>
              <button type="button" id="remove-avatar-btn" class="btn btn-ghost btn-xs" style="color:var(--danger-text); display:none;">Remove</button>
              <span id="avatar-upload-status" class="hint" style="display:none;"></span>
            </div>
          </div>
        </div>

        <form id="profile-form" class="settings-form">
          <input type="hidden" name="avatar_url" id="avatar_url_input" value={user.avatar_url || ""} />
          <div class="form-row">
            <div>
              <label class="label" for="username">Username</label>
              <input
                id="username"
                name="username"
                type="text"
                class="input"
                value={user.username}
                required
                minlength="3"
                maxlength="30"
                pattern="[a-zA-Z0-9_]+"
                autocomplete="username"
              />
              <p class="hint" style="margin-top:.25rem">
                Letters, numbers, underscores only.
              </p>
            </div>
            <div>
              <label class="label" for="full_name"
                >Full Name <span class="muted">(optional)</span></label
              >
              <input
                id="full_name"
                name="full_name"
                type="text"
                class="input"
                value={user.full_name ?? ""}
                maxlength="80"
                autocomplete="name"
              />
            </div>
          </div>

          <div class="form-row">
            <div>
              <label class="label" for="department">Department</label>
              <select id="department" name="department" required class="input">
                {
                  DEPARTMENTS.map((d) => (
                    <option value={d} selected={d === user.department}>
                      {d}
                    </option>
                  ))
                }
              </select>
            </div>
            <div>
              <label class="label" for="level">Level</label>
              <select id="level" name="level" required class="input">
                {
                  LEVELS.map((l) => (
                    <option value={l} selected={l === user.level}>
                      {l}
                    </option>
                  ))
                }
              </select>
            </div>
          </div>

          <div id="profile-error" class="alert alert-danger" hidden></div>

          <div style="display:flex;justify-content:flex-end;padding-top:.25rem">
            <button
              type="submit"
              id="profile-btn"
              class="btn btn-primary btn-sm">Save changes</button
            >
          </div>
        </form>
      </section>

      <hr class="divider" style="margin:2rem 0" />

      <!-- ── Account ──────────────────────────────────────────────────────── -->
      <section class="settings-section" id="account">
        <div class="section-header">
          <h2 class="section-title">Account</h2>
          <p class="muted">Change your login password.</p>
        </div>

        <form id="password-form" class="settings-form">
          <div>
            <label class="label" for="current_password">Current Password</label>
            <input
              id="current_password"
              name="current_password"
              type="password"
              class="input"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            />
          </div>
          <div class="form-row">
            <div>
              <label class="label" for="new_password">New Password</label>
              <input
                id="new_password"
                name="new_password"
                type="password"
                class="input"
                placeholder="Min. 8 characters"
                required
                minlength="8"
                autocomplete="new-password"
              />
            </div>
            <div>
              <label class="label" for="confirm_password"
                >Confirm New Password</label
              >
              <input
                id="confirm_password"
                name="confirm_password"
                type="password"
                class="input"
                placeholder="Repeat new password"
                required
                autocomplete="new-password"
              />
            </div>
          </div>

          <div id="password-error" class="alert alert-danger" hidden></div>

          <div style="display:flex;justify-content:flex-end;padding-top:.25rem">
            <button
              type="submit"
              id="password-btn"
              class="btn btn-primary btn-sm">Change password</button
            >
          </div>
        </form>
      </section>

      <hr class="divider" style="margin:2rem 0" />

      <!-- ── Identity ─────────────────────────────────────────────────────── -->
      <section class="settings-section" id="identity">
        <div class="section-header">
          <h2 class="section-title">Identity</h2>
          <p class="muted">Read-only — these values are permanent.</p>
        </div>

        <div class="identity-grid">
          <div class="identity-item">
            <span class="label" style="margin-bottom:.25rem">Pulse ID</span>
            <div
              style="display:flex;align-items:center;gap:.625rem;flex-wrap:wrap"
            >
              <code class="pulse-id" style="font-size:.875rem;padding:4px 10px"
                >{user.pulse_id}</code
              >
              <span class="hint">Permanent — cannot be changed</span>
            </div>
          </div>
          <div class="identity-item">
            <span class="label" style="margin-bottom:.25rem">Role</span>
            <span
              class={user.role === "admin"
                ? "badge badge-warn"
                : "badge badge-gray"}
            >
              {user.role === "admin" ? "◈ Admin" : "◎ User"}
            </span>
          </div>
          <div class="identity-item">
            <span class="label" style="margin-bottom:.25rem">Department</span>
            <span style="font-size:.9375rem;color:var(--text)"
              >{user.department}</span
            >
          </div>
          <div class="identity-item">
            <span class="label" style="margin-bottom:.25rem">Level</span>
            <span style="font-size:.9375rem;color:var(--text)"
              >{user.level}</span
            >
          </div>
        </div>

        <div class="danger-zone">
          <h3 class="danger-title">Danger Zone</h3>
          <div class="danger-row">
            <div>
              <p style="font-size:.875rem;font-weight:500;color:var(--text)">
                Delete account
              </p>
              <p class="hint">
                Permanently remove your account and all your posts.
              </p>
            </div>
            <button class="btn btn-danger btn-sm" disabled title="Coming soon"
              >Delete account</button
            >
          </div>
        </div>
      </section>
    </div>
  </div>
</AppLayout>

<script>
  // Profile form
  document
    .getElementById("profile-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = document.getElementById("profile-btn") as HTMLButtonElement;
      const errBox = document.getElementById("profile-error") as HTMLElement;
      const get = (n: string) =>
        (form.elements.namedItem(n) as HTMLInputElement)?.value.trim();

      errBox.hidden = true;
      btn.disabled = true;
      btn.textContent = "Saving…";

      const res = await fetch("/api/auth/update-profile", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          action: "update_profile",
          username: get("username"),
          full_name: get("full_name"),
          department: get("department"),
          level: get("level"),
          avatar_url: (document.getElementById("avatar_url_input") as HTMLInputElement)?.value || undefined,
        }),
      });

      if (res.ok) {
        window.location.href = "/settings?success=profile";
      } else {
        const { error } = await res.json();
        errBox.textContent = error;
        errBox.hidden = false;
        btn.disabled = false;
        btn.textContent = "Save changes";
      }
    });

  // Avatar logic
  const uploadAvatarBtn = document.getElementById("upload-avatar-btn");
  const avatarUpload = document.getElementById("avatar-upload") as HTMLInputElement | null;
  const removeAvatarBtn = document.getElementById("remove-avatar-btn");
  const avatarUrlInput = document.getElementById("avatar_url_input") as HTMLInputElement | null;
  const avatarPreviewImg = document.getElementById("avatar-preview-img") as HTMLImageElement | null;
  const avatarPreviewInitial = document.getElementById("avatar-preview-initial");
  const avatarStatus = document.getElementById("avatar-upload-status");

  if (avatarUrlInput && avatarUrlInput.value) {
    if (removeAvatarBtn) removeAvatarBtn.style.display = 'inline-flex';
  }

  uploadAvatarBtn?.addEventListener('click', () => avatarUpload?.click());
  
  removeAvatarBtn?.addEventListener('click', () => {
    if (avatarUrlInput) avatarUrlInput.value = '';
    if (avatarPreviewImg) {
      avatarPreviewImg.style.display = 'none';
      avatarPreviewImg.src = '';
    }
    if (avatarPreviewInitial) avatarPreviewInitial.style.display = 'inline';
    if (removeAvatarBtn) removeAvatarBtn.style.display = 'none';
  });

  avatarUpload?.addEventListener('change', async (e) => {
    const target = e.target as HTMLInputElement;
    const file = target.files?.[0];
    if (!file) return;

    if (avatarStatus) {
      avatarStatus.textContent = "Uploading...";
      avatarStatus.style.display = "inline";
      avatarStatus.style.color = "var(--text-2)";
    }

    const formData = new FormData();
    formData.append("file", file);

    try {
      const res = await fetch("/api/upload", {
        method: "POST",
        body: formData,
      });

      if (!res.ok) throw new Error("Failed to upload image");
      const data = await res.json();

      // Update preview and hidden input
      if (avatarUrlInput) avatarUrlInput.value = data.url;
      if (avatarPreviewImg) {
        avatarPreviewImg.src = data.url;
        avatarPreviewImg.style.display = 'block';
      }
      if (avatarPreviewInitial) avatarPreviewInitial.style.display = 'none';
      if (removeAvatarBtn) removeAvatarBtn.style.display = 'inline-flex';
      
      if (avatarStatus) {
        avatarStatus.textContent = "Click 'Save changes' below to apply";
        avatarStatus.style.color = "var(--accent)";
      }
    } catch (err) {
      if (avatarStatus) {
        avatarStatus.textContent = "Upload failed.";
        avatarStatus.style.color = "var(--danger-text)";
      }
    }
  });

  // Password form
  document
    .getElementById("password-form")
    ?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const btn = document.getElementById("password-btn") as HTMLButtonElement;
      const errBox = document.getElementById("password-error") as HTMLElement;
      const get = (n: string) =>
        (form.elements.namedItem(n) as HTMLInputElement)?.value;

      const newPwd = get("new_password");
      const conf = get("confirm_password");

      errBox.hidden = true;
      if (newPwd !== conf) {
        errBox.textContent = "New passwords do not match.";
        errBox.hidden = false;
        return;
      }

      btn.disabled = true;
      btn.textContent = "Changing…";

      const res = await fetch("/api/auth/update-profile", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          action: "change_password",
          current_password: get("current_password"),
          new_password: newPwd,
        }),
      });

      if (res.ok) {
        window.location.href = "/settings?success=password";
      } else {
        const { error } = await res.json();
        errBox.textContent = error;
        errBox.hidden = false;
        btn.disabled = false;
        btn.textContent = "Change password";
      }
    });

  // Smooth scroll nav
  document.querySelectorAll(".settings-link").forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      document
        .querySelectorAll(".settings-link")
        .forEach((l) => l.classList.remove("active"));
      link.classList.add("active");
      const id = (link as HTMLElement).dataset.section;
      document
        .getElementById(id!)
        ?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>

<style>
  .settings-layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
    padding: 1.5rem 1.25rem;
    max-width: 820px;
  }

  @media (max-width: 640px) {
    .settings-layout {
      grid-template-columns: 1fr;
    }
    .settings-nav {
      display: flex;
      gap: 0.25rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.75rem;
    }
  }

  .settings-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
    position: sticky;
    top: 80px;
    align-self: start;
  }

  .settings-link {
    display: block;
    padding: 0.4375rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    transition:
      background var(--ease),
      color var(--ease);
  }

  .settings-link:hover,
  .settings-link.active {
    background: var(--bg-2);
    color: var(--text);
  }

  .settings-content {
    min-width: 0;
  }
  .settings-section {
    scroll-margin-top: 80px;
  }
  .section-header {
    margin-bottom: 1.25rem;
  }
  .section-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .avatar-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--bg-2);
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  .settings-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 520px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .identity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 520px) {
    .identity-grid {
      grid-template-columns: 1fr;
    }
  }

  .identity-item {
    background: var(--bg-2);
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .danger-zone {
    border: 1px solid rgba(185, 28, 28, 0.25);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .danger-title {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--danger-text);
    padding: 0.625rem 1rem;
    background: var(--danger-bg);
    border-bottom: 1px solid rgba(185, 28, 28, 0.15);
  }

  .danger-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    flex-wrap: wrap;
  }
</style>
