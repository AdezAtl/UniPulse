---
import AppLayout from "../../layouts/AppLayout.astro";
import { getUserByUsername, getMessages, markMessagesRead } from "../../lib/db";
import { formatRelativeTime, parseDbDate } from "../../lib/utils";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const { username } = Astro.params;
if (!username || username === user.username) return Astro.redirect("/messages");

const otherUser = getUserByUsername(username);
if (!otherUser) return Astro.redirect("/messages");

markMessagesRead(otherUser.id, user.id);
const messages = getMessages(user.id, otherUser.id);
---

<AppLayout title={`Chat with ${otherUser.username} · UniPulse`} activeNav="messages" user={user}>
  <div class="chat-container">
    <div class="chat-header">
      <a href="/messages" class="btn btn-ghost btn-sm" aria-label="Back to messages">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </a>
      <a href={`/profile/${otherUser.username}`} class="chat-user-info">
        <div class="avatar avatar-sm">
          {otherUser.avatar_url ? <img src={otherUser.avatar_url} alt="" /> : otherUser.username.charAt(0).toUpperCase()}
        </div>
        <div style="font-weight: 600; color: var(--text-1);">{otherUser.full_name || otherUser.username}</div>
      </a>
    </div>

    <div class="chat-messages" id="chat-messages">
      {messages.length === 0 ? (
        <div class="empty-state" style="margin: auto;">
          <p class="empty-title">Say hello to {otherUser.username}!</p>
        </div>
      ) : (
        messages.map((msg, i) => {
          const isMine = msg.sender_id === user.id;
          const showTime = i === 0 || (parseDbDate(msg.created_at).getTime() - parseDbDate(messages[i-1].created_at).getTime() > 10 * 60 * 1000);
          return (
            <div class="msg-wrapper">
              {showTime && <div class="msg-time">{formatRelativeTime(msg.created_at)}</div>}
              <div class={`msg-bubble ${isMine ? 'mine' : 'theirs'}`}>
                {msg.content}
              </div>
            </div>
          )
        })
      )}
    </div>

    <div class="chat-composer">
      <form id="chat-form" class="chat-form">
        <input type="hidden" id="receiver-username" value={otherUser.username} />
        <input 
          type="text" 
          id="chat-input" 
          class="chat-input" 
          placeholder="Type a message..." 
          autocomplete="off" 
        />
        <button type="submit" class="btn btn-primary btn-sm chat-send-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
        </button>
      </form>
    </div>
  </div>
</AppLayout>

<script>
  const form = document.getElementById('chat-form') as HTMLFormElement;
  const input = document.getElementById('chat-input') as HTMLInputElement;
  const receiver = document.getElementById('receiver-username') as HTMLInputElement;
  const messagesContainer = document.getElementById('chat-messages');

  if (messagesContainer) {
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const content = input.value.trim();
    if (!content) return;

    // Optimistic UI update
    if (messagesContainer) {
      const wrapper = document.createElement('div');
      wrapper.className = 'msg-wrapper';
      wrapper.innerHTML = `<div class="msg-bubble mine" style="opacity: 0.7">${content}</div>`;
      
      const emptyState = messagesContainer.querySelector('.empty-state');
      if (emptyState) emptyState.remove();

      messagesContainer.appendChild(wrapper);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    input.value = '';
    
    const res = await fetch('/api/messages/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ receiverUsername: receiver.value, content })
    });

    if (!res.ok) {
      alert('Failed to send message');
      window.location.reload();
    } else {
      // Reload or just mark optimistic message as sent
      // For simplicity in offline mode with sync SQLite, a reload ensures everything is in sync
      window.location.reload();
    }
  });
</script>

<style>
  .chat-container {
    display: flex;
    flex-direction: column;
    height: calc(100dvh - 60px); /* Fill app shell */
    max-width: 800px;
    margin: 0 auto;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    background: var(--bg);
  }

  .chat-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    z-index: 10;
  }

  .chat-user-info {
    display: flex;
    align-items: center;
    gap: .75rem;
    text-decoration: none;
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }

  .msg-wrapper {
    display: flex;
    flex-direction: column;
  }

  .msg-time {
    text-align: center;
    font-size: .75rem;
    color: var(--text-3);
    margin: 1rem 0 .5rem;
  }

  .msg-bubble {
    max-width: 75%;
    padding: .5rem 1rem;
    border-radius: 1.25rem;
    font-size: .9375rem;
    line-height: 1.4;
    word-break: break-word;
  }

  .msg-bubble.mine {
    align-self: flex-end;
    background: var(--accent);
    color: white;
    border-bottom-right-radius: 0.25rem;
  }

  .msg-bubble.theirs {
    align-self: flex-start;
    background: var(--bg-2);
    color: var(--text-1);
    border-bottom-left-radius: 0.25rem;
  }

  .chat-composer {
    padding: 1rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
  }

  .chat-form {
    display: flex;
    gap: .5rem;
    background: var(--bg-2);
    padding: .5rem;
    border-radius: 99px;
    border: 1px solid var(--border);
  }

  .chat-form:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
  }

  .chat-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 0 .5rem;
    color: var(--text-1);
    font-size: .9375rem;
  }

  .chat-send-btn {
    border-radius: 50%;
    width: 36px;
    height: 36px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .chat-container {
      height: calc(100dvh - 120px); /* Account for bottom nav */
      border: none;
    }
  }
</style>
