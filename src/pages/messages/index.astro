---
import AppLayout from "../../layouts/AppLayout.astro";
import { getConversations, getAllUsers } from "../../lib/db";
import { formatRelativeTime } from "../../lib/utils";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const conversations = getConversations(user.id);
const allUsers = getAllUsers().filter(u => u.id !== user.id && !u.is_banned);
---

<AppLayout title="Messages · UniPulse" activeNav="messages" user={user}>
  <div class="messages-container" style="max-width: 600px; margin: 0 auto; padding-top: 1rem;">
    <div class="messages-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h1 style="font-size: 1.5rem; font-weight: 700; color: var(--text-1);">Messages</h1>
      <button id="new-msg-btn" class="btn btn-primary btn-sm" style="display: flex; align-items: center; gap: 0.25rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
        New Message
      </button>
    </div>

    {conversations.length === 0 ? (
      <div class="empty-state">
        <p class="empty-icon">💬</p>
        <p class="empty-title">No messages yet</p>
        <p class="empty-sub">Start a conversation from someone's profile or click New Message.</p>
      </div>
    ) : (
      <div class="conversations-list" style="display: flex; flex-direction: column; gap: 0.5rem;">
        {conversations.map(c => (
          <a href={`/messages/${c.user.username}`} class="conversation-item">
            <div class="avatar avatar-md">
              {c.user.avatar_url ? <img src={c.user.avatar_url} alt="" /> : c.user.username.charAt(0).toUpperCase()}
            </div>
            <div class="convo-info">
              <div class="convo-header">
                <span class="convo-name">{c.user.full_name || c.user.username}</span>
                <span class="convo-time">{formatRelativeTime(c.last_message.created_at)}</span>
              </div>
              <div class={`convo-preview ${c.unread_count > 0 ? 'unread' : ''}`}>
                {c.last_message.sender_id === user.id ? 'You: ' : ''}{c.last_message.content}
              </div>
            </div>
            {c.unread_count > 0 && (
              <div class="unread-badge">{c.unread_count}</div>
            )}
          </a>
        ))}
      </div>
    )}
  </div>

  <!-- New Message Modal -->
  <div id="new-msg-modal" class="modal-overlay" hidden>
    <div class="modal-box" style="max-width: 480px; display: flex; flex-direction: column; gap: 1rem; max-height: 80vh;">
      <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 0.75rem;">
        <h2 style="font-size: 1.25rem; font-weight: 600; color: var(--text-1);">New Message</h2>
        <button id="modal-close-btn" class="btn btn-ghost btn-sm" style="padding: 0.25rem; border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;">✕</button>
      </div>
      
      <div style="position: relative;">
        <input 
          type="text" 
          id="user-search-input" 
          placeholder="Search students..." 
          style="width: 100%; padding: 0.625rem 1rem; border-radius: var(--radius-lg); border: 1px solid var(--border); background: var(--bg-2); color: var(--text-1); outline: none; transition: border-color 0.15s;" 
          autocomplete="off"
        />
      </div>

      <div id="users-list-container" style="flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 0.25rem; max-height: 350px; padding-right: 0.25rem;">
        {allUsers.map(u => (
          <a href={`/messages/${u.username}`} class="user-select-item" data-username={u.username} data-fullname={u.full_name || ''} style="display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem; border-radius: var(--radius-md); text-decoration: none; color: var(--text-1); transition: background 0.15s;">
            <div class="avatar avatar-sm">
              {u.avatar_url ? <img src={u.avatar_url} alt="" /> : u.username.charAt(0).toUpperCase()}
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-weight: 600; font-size: 0.9375rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@{u.username}</div>
              {u.full_name && <div style="font-size: 0.8125rem; color: var(--text-3); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{u.full_name}</div>}
            </div>
          </a>
        ))}
        {allUsers.length === 0 && (
          <div style="text-align: center; color: var(--text-3); padding: 1.5rem 0;">No other students registered yet.</div>
        )}
      </div>
    </div>
  </div>
</AppLayout>

<style>
  .conversation-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: var(--radius-lg);
    background: var(--bg);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }
  .conversation-item:hover {
    background: var(--bg-2);
    transform: translateY(-2px);
  }
  .convo-info {
    flex: 1;
    min-width: 0;
  }
  .convo-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
  }
  .convo-name {
    font-weight: 600;
    color: var(--text-1);
  }
  .convo-time {
    font-size: 0.75rem;
    color: var(--text-3);
  }
  .convo-preview {
    font-size: 0.875rem;
    color: var(--text-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .convo-preview.unread {
    color: var(--text-1);
    font-weight: 600;
  }
  .unread-badge {
    background: var(--accent);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.125rem 0.5rem;
    border-radius: 99px;
  }
  .user-select-item:hover {
    background: var(--bg-2);
  }
</style>

<script>
  const modal = document.getElementById('new-msg-modal');
  const openBtn = document.getElementById('new-msg-btn');
  const closeBtn = document.getElementById('modal-close-btn');
  const searchInput = document.getElementById('user-search-input') as HTMLInputElement;
  const userItems = document.querySelectorAll('.user-select-item');

  openBtn?.addEventListener('click', () => {
    if (modal) {
      modal.hidden = false;
      if (searchInput) {
        searchInput.value = '';
        searchInput.focus();
      }
      userItems.forEach(item => {
        (item as HTMLElement).style.display = 'flex';
      });
    }
  });

  closeBtn?.addEventListener('click', () => {
    if (modal) modal.hidden = true;
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.hidden = true;
    }
  });

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    userItems.forEach(item => {
      const el = item as HTMLElement;
      const username = (el.getAttribute('data-username') || '').toLowerCase();
      const fullname = (el.getAttribute('data-fullname') || '').toLowerCase();
      if (username.includes(query) || fullname.includes(query)) {
        el.style.display = 'flex';
      } else {
        el.style.display = 'none';
      }
    });
  });
</script>
