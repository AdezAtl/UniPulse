---
import AppLayout from "../layouts/AppLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getFeedPosts, getLikedPostIds } from "../lib/db";

const user = Astro.locals.user!;
const posts = getFeedPosts().sort((a, b) => b.like_count - a.like_count);
const likedIds = getLikedPostIds(user.id);
const likedSet = new Set(likedIds);
---

<AppLayout activeNav="popular" user={user} title="Popular · UniPulse">
  <div class="page-header" style="margin-bottom: 1rem; border-bottom: none;"><h1 class="page-title">Popular Posts</h1></div>
  
  <div class="feed-posts">
    {
      !posts || posts.length === 0 ? (
        <div class="empty-state">
          <p class="empty-icon">📈</p>
          <p class="empty-title">Nothing popular yet</p>
        </div>
      ) : (
        posts.map((post) => (
          <PostCard
            post={post}
            isLiked={likedSet.has(post.id)}
            isAdmin={Astro.locals.isAdmin}
            currentUserId={user.id}
          />
        ))
      )
    }
  </div>
</AppLayout>
