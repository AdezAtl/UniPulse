---
import AppLayout from "../../layouts/AppLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getAllUsers, getUserPosts, getSavedPosts, getUserVotes, getSavedPostIds, getFollowingIds } from "../../lib/db";
import { formatDate } from "../../lib/utils";

const { username } = Astro.params;
const viewer = Astro.locals.user!;
const isAdmin = Astro.locals.isAdmin;

const allUsers = getAllUsers();
const profileUser = allUsers.find((u) => u.username === username);
if (!profileUser) return Astro.redirect("/feed");

const posts = getUserPosts(profileUser.id);
const isOwnPage = viewer.id === profileUser.id;

const savedPosts = isOwnPage ? getSavedPosts(viewer.id) : [];
const userVotes = getUserVotes(viewer.id);
const savedIds = getSavedPostIds(viewer.id);
const followingIds = getFollowingIds(viewer.id);
---

<AppLayout
  activeNav="profile"
  user={viewer}
  title={`@${profileUser.username} · UniPulse`}
>
  <div
    style="display:flex;gap:1rem;align-items:flex-start;padding:1.25rem;border-bottom:1px solid var(--border)"
  >
    <div style="position:relative;flex-shrink:0">
      <div
        class="avatar"
        style="width:64px;height:64px;font-size:1.5rem;font-weight:600"
      >
        {
          profileUser.avatar_url ? (
            <img
              src={profileUser.avatar_url}
              alt=""
              style="width:100%;height:100%;object-fit:cover"
            />
          ) : (
            profileUser.username.charAt(0).toUpperCase()
          )
        }
      </div>
      {
        profileUser.role === "admin" && (
          <span
            class="badge badge-warn"
            style="position:absolute;bottom:-4px;right:-4px"
          >
            Admin
          </span>
        )
      }
    </div>
    <div style="flex:1;min-width:0">
      <div
        style="display:flex;align-items:baseline;flex-wrap:wrap;gap:.5rem;margin-bottom:.375rem"
      >
        <h1 style="font-size:1.125rem;font-weight:600;color:var(--text)">
          @{profileUser.username}
        </h1>
        {
          profileUser.full_name && (
            <span class="muted">{profileUser.full_name}</span>
          )
        }
      </div>
      <div
        style="display:flex;align-items:center;flex-wrap:wrap;gap:.375rem;margin-bottom:.25rem"
      >
        <span class="pulse-id">{profileUser.pulse_id}</span>
        <span class="hint">·</span>
        <span class="hint">{profileUser.department}</span>
        <span class="hint">·</span>
        <span class="hint">{profileUser.level}</span>
      </div>
      <p class="hint">Joined {formatDate(profileUser.created_at)}</p>
    </div>
    {
      isOwnPage ? (
        <a
          href="/settings"
          class="btn btn-secondary btn-sm"
          style="align-self:flex-start"
        >
          Edit profile
        </a>
      ) : (
        <button class="btn btn-primary btn-sm follow-btn" data-user-id={profileUser.id} style="align-self:flex-start">
          {Astro.locals.user ? (followingIds.has(profileUser.id) ? 'Following' : 'Follow +') : 'Follow +'}
        </button>
      )
    }
  </div>

  <div class="tabs-bar" style="display: flex; gap: 1rem; padding: 0 1.25rem; border-bottom: 1px solid var(--border); background: var(--bg-2);">
    <button class="tab-btn active" data-target="tab-posts">Posts ({posts.length})</button>
    {isOwnPage && <button class="tab-btn" data-target="tab-saved">Saved</button>}
  </div>

  <div id="tab-posts" class="tab-content" style="display: block;">
    {
      posts.length === 0 ? (
        <div class="empty-state">
          <p class="empty-title">No posts yet</p>
          {isOwnPage && (
            <p class="empty-sub">Go share something on the feed!</p>
          )}
        </div>
      ) : (
        posts.map((post) => (
          <PostCard
            post={post}
            userVote={userVotes[post.id] || 0}
            isSaved={savedIds.has(post.id)}
            isFollowing={followingIds.has(post.author_id)}
            isAdmin={isAdmin}
            currentUserId={viewer.id}
          />
        ))
      )
    }
  </div>

  {isOwnPage && (
    <div id="tab-saved" class="tab-content" style="display: none;">
      {
        savedPosts.length === 0 ? (
          <div class="empty-state">
            <p class="empty-title">No saved posts yet</p>
          </div>
        ) : (
          savedPosts.map((post) => (
            <PostCard
              post={post}
              userVote={userVotes[post.id] || 0}
              isSaved={savedIds.has(post.id)}
              isFollowing={followingIds.has(post.author_id)}
              isAdmin={isAdmin}
              currentUserId={viewer.id}
            />
          ))
        )
      }
    </div>
  )}
</AppLayout>

<script>
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const target = (btn as HTMLElement).dataset.target;
      document.querySelectorAll('.tab-content').forEach(tc => {
        (tc as HTMLElement).style.display = tc.id === target ? 'block' : 'none';
      });
    });
  });
</script>

<style>
  .tab-btn {
    background: none; border: none; padding: .875rem 0; font-size: .875rem; font-weight: 600;
    color: var(--text-2); cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px;
  }
  .tab-btn.active { color: var(--text-1); border-bottom-color: var(--accent); }
  .tab-btn:hover:not(.active) { color: var(--text-1); }
</style>
