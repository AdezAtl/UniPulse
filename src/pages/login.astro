---
import AuthLayout from '../layouts/AuthLayout.astro';

const error = Astro.url.searchParams.get('error');

// ✅ Validate redirect server-side — must be a relative path
const rawRedirect = Astro.url.searchParams.get('redirect') ?? '/feed';
const safeRedirect = rawRedirect.startsWith('/') && !rawRedirect.startsWith('//')
  ? rawRedirect
  : '/feed';
---

<AuthLayout title="Sign In · UniPulse">
  <h2 style="font-size:1rem;font-weight:600;margin-bottom:.25rem">Welcome back</h2>
  <p class="muted" style="margin-bottom:1.5rem">Sign in with your username, email, or Pulse ID.</p>

  {error === 'banned' && (
    <div class="alert alert-danger" style="margin-bottom:1rem">
      Your account has been suspended. Contact your campus admin.
    </div>
  )}
  {error === 'unauthorized' && (
    <div class="alert alert-danger" style="margin-bottom:1rem">
      You don't have permission to access that page.
    </div>
  )}
  {error === 'server' && (
    <div class="alert alert-danger" style="margin-bottom:1rem">
      A server error occurred. Please try again later.
    </div>
  )}

  <form id="login-form" style="display:flex;flex-direction:column;gap:1rem">
    <input type="hidden" id="safe-redirect" value={safeRedirect} />

    <div>
      <label class="label" for="identifier">Username / Email / Pulse ID</label>
      <input id="identifier" name="identifier" type="text"
        placeholder="e.g. john_doe, UP-ABC123, or email@uni.edu"
        autocomplete="username" required class="input" />
      <p id="id-hint" class="hint" style="margin-top:.375rem;min-height:1rem"></p>
    </div>

    <div>
      <label class="label" for="password">Password</label>
      <input id="password" name="password" type="password"
        placeholder="••••••••" autocomplete="current-password" required class="input" />
    </div>

    <div id="login-error" class="alert alert-danger" hidden></div>

    <button type="submit" id="login-btn" class="btn btn-primary w-full" style="padding:.625rem;margin-top:.25rem">
      Sign in
    </button>
  </form>

  <p class="hint text-center" style="margin-top:1.5rem">
    New to UniPulse?
    <a href="/signup" style="color:var(--accent);text-decoration:none;font-weight:500">Create an account</a>
  </p>
</AuthLayout>

<script>
  // ✅ Import both signIn AND the supabase client so we can listen for auth state
  import { signIn, supabase } from '../lib/supabase';

  const identifier   = document.getElementById('identifier')    as HTMLInputElement;
  const password     = document.getElementById('password')      as HTMLInputElement;
  const hint         = document.getElementById('id-hint')       as HTMLElement;
  const errorBox     = document.getElementById('login-error')   as HTMLElement;
  const btn          = document.getElementById('login-btn')     as HTMLButtonElement;
  const safeRedirect = document.getElementById('safe-redirect') as HTMLInputElement;

  if (!identifier || !password || !hint || !errorBox || !btn || !safeRedirect) {
    console.error('[login] One or more required DOM elements are missing.');
  }

  identifier?.addEventListener('input', () => {
    const v = identifier.value.trim();
    if (v.toUpperCase().startsWith('UP-')) hint.textContent = 'Detected: Pulse ID';
    else if (v.includes('@'))              hint.textContent = 'Detected: Email address';
    else if (v.length > 0)                hint.textContent = 'Detected: Username';
    else                                  hint.textContent = '';
  });

  document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const id  = identifier.value.trim();
    const pwd = password.value;

    btn.disabled    = true;
    btn.textContent = 'Signing in…';
    errorBox.hidden = true;

    try {
      const { error } = await signIn(id, pwd);

      if (error) {
        errorBox.textContent =
          typeof error === 'string'
            ? error
            : (error as Error)?.message ?? 'Something went wrong. Please try again.';
        errorBox.hidden = false;
      } else {
        // ✅ Wait for the auth cookie to be fully written before navigating.
        //    Redirecting immediately after signInWithPassword() can race against
        //    the cookie being set, causing the middleware to see no session.
        const { data: { subscription } } = supabase.auth.onAuthStateChange((event) => {
          if (event === 'SIGNED_IN') {
            subscription.unsubscribe(); // ✅ Clean up the listener after use
            window.location.href = safeRedirect.value;
          }
        });

        // ✅ Fallback: if SIGNED_IN doesn't fire within 3s, redirect anyway.
        //    This handles edge cases where the event was already fired before
        //    the listener was registered.
        setTimeout(() => {
          subscription.unsubscribe();
          window.location.href = safeRedirect.value;
        }, 3000);
      }
    } catch (err) {
      console.error('[login] Unexpected error during sign in:', err);
      errorBox.textContent = 'Network error. Please check your connection and try again.';
      errorBox.hidden      = false;
      btn.disabled         = false;
      btn.textContent      = 'Sign in';
    }
    // Note: we intentionally don't reset the button in `finally` on success —
    // the button should stay disabled while the redirect is in progress.
  });
</script>