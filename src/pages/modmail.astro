---
import AppLayout from "../layouts/AppLayout.astro";
const user = Astro.locals.user!;
if (user.role !== 'admin') {
  return Astro.redirect('/feed');
}
---

<AppLayout activeNav="modmail" user={user} title="Mod Mail · UniPulse">
  <div class="page-header" style="margin-bottom: 1rem; border-bottom: none;"><h1 class="page-title">Mod Mail</h1></div>
  
  <div class="empty-state">
    <p class="empty-icon">✉️</p>
    <p class="empty-title">Inbox Zero!</p>
    <p class="empty-sub">No new mod mail messages.</p>
  </div>
</AppLayout>
