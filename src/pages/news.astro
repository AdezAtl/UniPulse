---
import AppLayout from "../layouts/AppLayout.astro";
import { getNews, createNews } from "../lib/db";
import { formatDate } from "../lib/utils";

const user = Astro.locals.user!;
const isAdmin = Astro.locals.isAdmin;

if (Astro.request.method === "POST" && isAdmin) {
  const form = await Astro.request.formData();
  const title = (form.get("title") as string)?.trim();
  const content = (form.get("content") as string)?.trim();
  if (title && content) {
    createNews(title, content, user.id);
    return Astro.redirect("/news");
  }
}

const newsItems = getNews();
---

<AppLayout activeNav="news" user={user} title="Campus News · UniPulse">
  <div class="page-header">
    <h1 class="page-title">Campus News</h1>
    {
      isAdmin && (
        <button id="open-news" class="btn btn-primary btn-sm">
          + Post News
        </button>
      )
    }
  </div>

  {
    isAdmin && (
      <div id="news-modal" class="modal-overlay" hidden>
        <div class="modal-box">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
            <h3 style="font-size:.9375rem;font-weight:600">Post Campus News</h3>
            <button id="news-close" class="btn btn-ghost btn-xs">
              ✕
            </button>
          </div>
          <form
            method="POST"
            style="display:flex;flex-direction:column;gap:.875rem"
          >
            <div>
              <>
                <label class="label">Title *</label>
                <input
                  name="title"
                  type="text"
                  required
                  maxlength="140"
                  class="input"
                  placeholder="News headline…"
                />
              </>
            </div>
            <div>
              <>
                <label class="label">Content *</label>
                <textarea
                  name="content"
                  required
                  rows="5"
                  maxlength="2000"
                  class="input"
                  style="resize:none"
                  placeholder="Full announcement…"
                />
              </>
            </div>
            <div style="display:flex;justify-content:flex-end;gap:.5rem">
              <button
                type="button"
                id="news-cancel"
                class="btn btn-secondary btn-sm"
              >
                Cancel
              </button>
              <button type="submit" class="btn btn-primary btn-sm">
                Publish
              </button>
            </div>
          </form>
        </div>
      </div>
    )
  }

  <div
    style="padding:1rem 1.25rem;display:flex;flex-direction:column;gap:.75rem"
  >
    {
      newsItems.length === 0 ? (
        <div class="empty-state">
          <>
            <p class="empty-icon">◫</p>
            <p class="empty-title">No announcements yet</p>
            <p class="empty-sub">Official campus news will appear here.</p>
          </>
        </div>
      ) : (
        newsItems.map((item) => (
          <article class="card" style="padding:1.25rem">
            <div style="display:flex;align-items:center;gap:.375rem;margin-bottom:.625rem;flex-wrap:wrap">
              <span class="badge badge-warn">Official</span>
              <span class="hint">{formatDate(item.created_at)}</span>
              <span class="hint">· @{item.author_username ?? "admin"}</span>
            </div>
            <h2 style="font-size:1rem;font-weight:600;color:var(--text);margin-bottom:.5rem;line-height:1.3">
              {item.title}
            </h2>
            <p
              class="muted"
              style="font-size:.9375rem;line-height:1.65;white-space:pre-wrap"
            >
              {item.content}
            </p>
          </article>
        ))
      )
    }
  </div>
</AppLayout>

<script>
  const modal = document.getElementById("news-modal") as HTMLElement;
  document
    .getElementById("open-news")
    ?.addEventListener("click", () => (modal.hidden = false));
  document
    .getElementById("news-close")
    ?.addEventListener("click", () => (modal.hidden = true));
  document
    .getElementById("news-cancel")
    ?.addEventListener("click", () => (modal.hidden = true));
</script>
