---
import AppLayout from '../layouts/AppLayout.astro';
import { fetchNews, createNews } from '../lib/supabase';
import { formatDate } from '../lib/utils';

const user    = Astro.locals.user!;
const isAdmin = Astro.locals.isAdmin;

if (Astro.request.method === 'POST' && isAdmin) {
  const form    = await Astro.request.formData();
  const title   = (form.get('title') as string)?.trim();
  const content = (form.get('content') as string)?.trim();
  if (title && content) {
    await createNews(title, content, user.id);
    return Astro.redirect('/news');
  }
}

const { data: newsItems } = await fetchNews();
---

<AppLayout activeNav="news" user={user} title="Campus News · UniPulse">
  <div class="page-header">
    <h1 class="page-title">Campus News</h1>
    {isAdmin && (
      <button id="open-news" class="btn btn-primary btn-sm">+ Post News</button>
    )}
  </div>

  {isAdmin && (
    <div id="news-modal" class="modal-overlay" hidden>
      <div class="modal-box">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
          <h3 style="font-size:.9375rem;font-weight:600">Post Campus News</h3>
          <button id="news-close" class="btn btn-ghost btn-xs">✕</button>
        </div>
        <form method="POST" style="display:flex;flex-direction:column;gap:.875rem">
          <div>
            <label class="label" for="news-title">Title *</label>
            <input id="news-title" name="title" type="text" required maxlength="140"
              class="input" placeholder="News headline…" />
          </div>
          <div>
            <label class="label" for="news-content">Content *</label>
            <textarea id="news-content" name="content" required rows="5" maxlength="2000"
              class="input" style="resize:none" placeholder="Full announcement…"></textarea>
          </div>
          <div style="display:flex;justify-content:flex-end;gap:.5rem">
            <button type="button" id="news-cancel" class="btn btn-secondary btn-sm">Cancel</button>
            <button type="submit" class="btn btn-primary btn-sm">Publish</button>
          </div>
        </form>
      </div>
    </div>
  )}

  <div class="news-list">
    {!newsItems || newsItems.length === 0
      ? (
        <div class="empty-state">
          <p class="empty-icon">◫</p>
          <p class="empty-title">No announcements yet</p>
          <p class="empty-sub">Official campus news will appear here.</p>
        </div>
      )
      : newsItems.map((item: any) => (
        <article class="news-card card">
          <div class="news-meta">
            <span class="badge badge-warn">Official</span>
            <span class="hint">{formatDate(item.created_at)}</span>
            <span class="hint">· @{item.author?.username ?? 'admin'}</span>
          </div>
          <h2 class="news-title">{item.title}</h2>
          <p class="news-body muted">{item.content}</p>
        </article>
      ))
    }
  </div>
</AppLayout>

<script>
  const modal = document.getElementById('news-modal');
  document.getElementById('open-news')?.addEventListener('click',   () => modal.hidden = false);
  document.getElementById('news-close')?.addEventListener('click',  () => modal.hidden = true);
  document.getElementById('news-cancel')?.addEventListener('click', () => modal.hidden = true);
</script>

<style>
  .news-list { padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: .75rem; }
  .news-card { padding: 1.25rem; }
  .news-meta { display: flex; align-items: center; gap: .375rem; margin-bottom: .625rem; flex-wrap: wrap; }
  .news-title { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: .5rem; line-height: 1.3; }
  .news-body  { font-size: .9375rem; line-height: 1.65; white-space: pre-wrap; }
</style>
