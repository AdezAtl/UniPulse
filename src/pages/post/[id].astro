---
import AppLayout from "../../layouts/AppLayout.astro";
import PostCard from "../../components/PostCard.astro";
import {
  getPostById,
  getPostComments,
  getUserVotes,
  getSavedPostIds,
  getFollowingIds,
} from "../../lib/db";

const user = Astro.locals.user!;
const { id } = Astro.params;

if (!id) return Astro.redirect("/feed");

const post = getPostById(id);
if (!post) return Astro.redirect("/feed");

const comments = getPostComments(id);
const userVotes = getUserVotes(user.id);
const savedIds = getSavedPostIds(user.id);
const followingIds = getFollowingIds(user.id);
---

<AppLayout title={`Post by @${post.username} · UniPulse`} user={user}>
  <div
    class="post-detail-container"
    style="max-width: 800px; margin: 0 auto; padding: 1rem 0 140px; position: relative;"
  >
    <PostCard
      post={post}
      userVote={userVotes[post.id] || 0}
      isSaved={savedIds.has(post.id)}
      isFollowing={followingIds.has(post.author_id)}
      isAdmin={Astro.locals.isAdmin}
      currentUserId={user.id}
    />

    <div class="comments-section" style="margin-top: 2rem;">
      <h3
        style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem; color: var(--text-1);"
      >
        Comments
      </h3>

      <div
        class="comments-list"
        style="display: flex; flex-direction: column; gap: 1rem;"
      >
        {
          comments.length === 0 ? (
            <p class="empty-state">
              No comments yet. Be the first to share your thoughts!
            </p>
          ) : (
            comments.map((c) => (
              <div class="comment-item" style="display: flex; gap: .75rem;">
                <div class="avatar avatar-sm">
                  {c.avatar_url ? (
                    <img src={c.avatar_url} alt="" />
                  ) : (
                    c.username?.charAt(0).toUpperCase()
                  )}
                </div>
                <div
                  class="comment-content"
                  style="flex: 1; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-md); padding: .75rem 1rem;"
                >
                  <div style="font-size: .8125rem; color: var(--text-2); margin-bottom: .25rem;">
                    <strong>u/{c.username}</strong> ·{" "}
                    {new Date(c.created_at).toLocaleDateString()}
                  </div>
                  <p style="font-size: .9375rem; color: var(--text-1); white-space: pre-wrap;">
                    {c.content}
                  </p>
                </div>
              </div>
            ))
          )
        }
      </div>

      <div class="comment-composer-fixed">
        <div class="comment-composer">
          <textarea
            id="comment-input"
            rows="1"
            placeholder="What are your thoughts?"
            style="width: 100%; border: none; background: transparent; resize: none; outline: none; font-family: var(--font); color: var(--text-1); overflow: hidden; min-height: 10px; padding: 0;"
          ></textarea>
          <div
            id="comment-actions"
            style="display: none; justify-content: flex-end; margin-top: .5rem;"
          >
            <button
              id="post-comment-btn"
              class="btn btn-primary btn-sm"
              data-post-id={post.id}>Comment</button
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  const commentInput = document.getElementById(
    "comment-input",
  ) as HTMLTextAreaElement;
  const postBtn = document.getElementById(
    "post-comment-btn",
  ) as HTMLButtonElement;
  const actionsDiv = document.getElementById(
    "comment-actions",
  ) as HTMLDivElement;

  commentInput?.addEventListener("input", function () {
    this.style.height = "auto";
    this.style.height = this.scrollHeight + "px";

    if (this.value.trim().length > 0) {
      actionsDiv.style.display = "flex";
    } else {
      actionsDiv.style.display = "none";
      this.style.height = "auto";
    }
  });

  postBtn?.addEventListener("click", async () => {
    const content = commentInput.value.trim();
    if (!content) return;

    postBtn.disabled = true;
    const res = await fetch("/api/comments", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ postId: postBtn.dataset.postId, content }),
    });
    postBtn.disabled = false;

    if (res.ok) {
      sessionStorage.setItem('showToast', 'Comment posted successfully!');
      window.location.reload();
    }
  });
</script>

<style>
  .comment-composer-fixed {
    position: fixed;
    bottom: 0;
    left: var(--nav-w);
    right: var(--panel-w);
    background: var(--bg);
    border-top: 1px solid var(--border);
    padding: 1rem;
    z-index: 30;
  }
  .comment-composer {
    max-width: 800px;
    margin: 0 auto;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 0.5rem 1rem;
    transition: all 0.2s ease;
  }
  .comment-composer:focus-within {
    background: var(--bg);
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
  }

  @media (max-width: 1024px) {
    .comment-composer-fixed {
      left: var(--nav-w);
      right: 0;
    }
  }
  @media (max-width: 640px) {
    .comment-composer-fixed {
      left: 0;
      right: 0;
      bottom: 60px;
      padding: 0.5rem;
    }
  }
</style>
