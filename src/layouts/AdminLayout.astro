---
import BaseLayout from './BaseLayout.astro';
import type { User } from '../lib/db';
interface Props { title?: string; user: User | null; }
const { title = 'Admin · UniPulse', user } = Astro.props;
const activeTab = new URL(Astro.request.url).searchParams.get('tab') ?? 'overview';
const nav = [
  { id:'overview', label:'Overview',  icon:'◈' },
  { id:'users',    label:'Users',     icon:'◎' },
  { id:'posts',    label:'Posts',     icon:'▦' },
  { id:'content',  label:'Content',   icon:'◉' },
  { id:'logs',     label:'Audit Log', icon:'◫' },
];
---
<BaseLayout title={title}>
  <div class="admin-shell">
    <div class="admin-mobile-header">
      <a href="/feed" class="logo-wrap" style="display:flex;align-items:center;gap:.5rem;text-decoration:none">
        <img src="/android-chrome-192x192.png" alt="UniPulse" style="width: 28px; height: 28px; border-radius: 6px;" />
        <span class="logo-text" style="font-weight:700;color:var(--text);font-size:1.1rem">Admin</span>
      </a>
      <button class="hamburger-btn" aria-label="Open menu" onclick="document.querySelector('.admin-sidebar').classList.toggle('open')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
    <aside class="admin-sidebar">
      <div class="sidebar-header">
        <a href="/feed" class="logo-wrap">
          <img src="/android-chrome-192x192.png" alt="UniPulse" style="width: 32px; height: 32px; border-radius: 6px;" />
          <span class="logo-text">UniPulse</span>
        </a>
        <span class="badge badge-admin" style="margin-top:0.375rem;align-self:flex-start">Admin</span>
      </div>
      <nav class="sidebar-nav">
        {nav.map(item => (
          <a href={`/admin?tab=${item.id}`} class={`sidebar-link ${activeTab===item.id?'active':''}`}>
            <span class="link-icon">{item.icon}</span>{item.label}
          </a>
        ))}
      </nav>
      <div class="sidebar-footer">
        <div class="current-user">
          <div class="avatar avatar-sm">{user?.username?.charAt(0).toUpperCase()}</div>
          <div style="min-width:0">
            <div class="truncate" style="font-size:0.8125rem;font-weight:500;color:var(--text-1)">@{user?.username}</div>
            <div class="pulse-id">{user?.pulse_id}</div>
          </div>
        </div>
        <button id="admin-theme-toggle" class="sidebar-link secondary" style="justify-content: flex-start; text-align: left; margin-bottom: 4px;">
          <span class="link-icon admin-sun-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </span>
          <span class="link-icon admin-moon-icon" style="display:none">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </span>
          Toggle Theme
        </button>
        <a href="/feed" class="sidebar-link secondary">← Back to Feed</a>
        <form action="/api/auth/signout" method="POST">
          <button type="submit" class="sidebar-link secondary signout">Sign out</button>
        </form>
      </div>
    </aside>
    <div class="admin-main"><slot /></div>
  </div>
</BaseLayout>

<script>
  const adminThemeToggle = document.getElementById('admin-theme-toggle');
  const adminSunIcon = document.querySelector('.admin-sun-icon') as HTMLElement;
  const adminMoonIcon = document.querySelector('.admin-moon-icon') as HTMLElement;

  const updateAdminIcons = () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (adminSunIcon && adminMoonIcon) {
      adminSunIcon.style.display = isDark ? 'none' : 'block';
      adminMoonIcon.style.display = isDark ? 'block' : 'none';
    }
  };

  updateAdminIcons();

  adminThemeToggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateAdminIcons();
  });
</script>

<style>
.admin-shell   { display:flex; min-height:100dvh; }
.admin-sidebar { width:220px; flex-shrink:0; display:flex; flex-direction:column; position:sticky; top:0; height:100dvh; overflow-y:auto; background:var(--bg); border-right:1px solid var(--border); }
.sidebar-header { padding:1.25rem 1rem 1rem; border-bottom:1px solid var(--border); display:flex; flex-direction:column; gap:0.25rem; }
.sidebar-nav    { flex:1; padding:0.75rem 0.625rem; display:flex; flex-direction:column; gap:2px; }
.sidebar-link   { display:flex; align-items:center; gap:0.6rem; padding:0.5rem 0.75rem; border-radius:8px; font-size:0.875rem; font-weight:500; text-decoration:none; cursor:pointer; background:none; border:none; width:100%; color:var(--text-2); transition:background 0.12s, color 0.12s; }
.sidebar-link:hover, .sidebar-link.active { background:var(--bg-2); color:var(--text-1); }
.sidebar-link.secondary { font-size:0.8125rem; }
.sidebar-link.signout   { color:var(--red); }
.sidebar-link.signout:hover { background:var(--red-bg); }
.link-icon  { font-size:0.75rem; opacity:0.7; }
.sidebar-footer { padding:0.75rem 0.625rem 1rem; border-top:1px solid var(--border); display:flex; flex-direction:column; gap:3px; }
.current-user   { display:flex; align-items:center; gap:0.5rem; padding:0.5rem 0.75rem; margin-bottom:3px; }
.admin-main { flex:1; min-width:0; padding:2rem 2.5rem 4rem; overflow-y:auto; }

.admin-mobile-header { display:none; justify-content:space-between; align-items:center; padding:0.75rem 1rem; border-bottom:1px solid var(--border); background:var(--bg); position:sticky; top:0; z-index:40; }
.hamburger-btn { background:none; border:none; color:var(--text); cursor:pointer; padding:0.25rem; display:flex; }

@media (max-width:768px) { 
  .admin-shell { flex-direction:column; }
  .admin-mobile-header { display:flex; }
  .admin-sidebar { 
    position:fixed; 
    top:57px; 
    left:0; 
    bottom:0; 
    height:calc(100dvh - 57px); 
    transform:translateX(-100%); 
    transition:transform 0.3s var(--ease); 
    z-index:50; 
    width:260px;
    box-shadow: 4px 0 16px rgba(0,0,0,0.1);
  } 
  .admin-sidebar.open { transform:translateX(0); }
  .admin-main { padding:1.25rem 1rem 3rem; } 
}
</style>
