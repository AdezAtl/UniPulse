---
import BaseLayout from './BaseLayout.astro';
interface Props { title?: string; }
const { title } = Astro.props;
---
<BaseLayout title={title}>
  <div class="auth-shell">
    <div class="auth-brand">
      <a href="/" class="logo-wrap">
        <span class="logo-mark">UP</span>
        <span class="logo-text">UniPulse</span>
      </a>
      <p class="muted" style="margin-top:0.25rem">The campus common room.</p>
    </div>
    <div class="auth-card card p-6 slide-up">
      <slot />
    </div>
    <p class="hint center" style="max-width:260px">Your identity stays yours. No real names required.</p>
  </div>
</BaseLayout>
<style>
.auth-shell { min-height:100dvh; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1.5rem; padding:2rem 1rem; }
.auth-brand { text-align:center; }
.auth-card  { width:100%; max-width:380px; }
</style>
