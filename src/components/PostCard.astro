---
import type { PostWithMeta } from "../lib/db";
import { formatRelativeTime, parseMarkdown } from "../lib/utils";

interface Props {
  post: PostWithMeta;
  isLiked?: boolean; // backwards compatibility
  userVote?: number;
  isSaved?: boolean;
  isFollowing?: boolean;
  commentCount?: number;
  isAdmin: boolean;
  currentUserId: string;
}
const {
  post,
  isLiked,
  userVote = isLiked ? 1 : 0,
  isSaved,
  isFollowing,
  commentCount = post.comment_count || 0,
  isAdmin,
  currentUserId,
} = Astro.props as Props;
---

<article
  class={`post-card ${post.is_flagged ? "is-flagged" : ""}`}
  data-post-id={post.id}
>
  <header class="post-header">
    <div class="post-header-left">
      <a href={`/profile/${post.username}`}>
        <div class="avatar avatar-sm">
          {
            post.avatar_url ? (
              <img src={post.avatar_url} alt="" />
            ) : (
              post.username.charAt(0).toUpperCase()
            )
          }
        </div>
      </a>
      <div class="post-meta-text">
        <span class="post-dept"
          >s/{
            post.department.toLowerCase().replace(/[^a-z0-9]/g, "") || "general"
          }</span
        >
        <a href={`/profile/${post.username}`} class="post-username"
          >u/{post.username}</a
        >
        <span class="post-time">· {formatRelativeTime(post.created_at)}</span>
      </div>
    </div>

    <div class="post-header-right">
      {
        post.author_id !== currentUserId && (
          <button
            class="btn btn-primary btn-xs follow-btn"
            data-user-id={post.author_id}
          >
            {isFollowing ? "Following" : "Follow +"}
          </button>
        )
      }

      {
        (isAdmin || post.author_id === currentUserId) && (
          <div class="admin-menu">
            <button
              class="admin-trigger"
              data-post-id={post.id}
              aria-label="Post options"
              aria-expanded="false"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <>
                  <circle cx="12" cy="5" r="1.5" />
                  <circle cx="12" cy="12" r="1.5" />
                  <circle cx="12" cy="19" r="1.5" />
                </>
              </svg>
            </button>

            <div class="admin-dropdown" data-dropdown={post.id} hidden>
              <div class="dropdown-label">Options</div>

              {isAdmin && (
                <button
                  class="dropdown-item"
                  data-post-action="flag"
                  data-post-id={post.id}
                  data-flagged={String(post.is_flagged)}
                >
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z" />
                    <line x1="4" y1="22" x2="4" y2="15" />
                  </svg>
                  {post.is_flagged ? "Remove flag" : "Flag for review"}
                </button>
              )}

              <button
                class="dropdown-item"
                data-post-action="edit"
                data-post-id={post.id}
                data-content={post.content}
              >
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <>
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                  </>
                </svg>
                Edit post
              </button>

              <div class="dropdown-sep" />

              <button
                class="dropdown-item danger"
                data-post-action="delete"
                data-post-id={post.id}
              >
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <>
                    <polyline points="3 6 5 6 21 6" />
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                  </>
                </svg>
                Delete post
              </button>

              {isAdmin && (
                <a href="/admin?tab=users" class="dropdown-item">
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                  </svg>
                  View in admin
                </a>
              )}
            </div>
          </div>
        )
      }
    </div>
  </header>

  <div class="post-body">
    <div class="post-content" set:html={parseMarkdown(post.content)} />

    {
      post.media_url && (
        <div class="post-media" style="margin-top: .75rem;">
          {post.media_url.match(/\.(mp4|webm)$/i) ? (
            <video
              src={post.media_url}
              controls
              style="max-width: 100%; max-height: 500px; border-radius: var(--radius-md); background: #000;"
            />
          ) : (
            <img
              src={post.media_url}
              alt="Post media"
              style="max-width: 100%; max-height: 500px; border-radius: var(--radius-md); object-fit: contain; background: var(--bg-2);"
              loading="lazy"
            />
          )}
        </div>
      )
    }
  </div>

  <footer class="post-footer">
    <div class="vote-group" data-post-id={post.id}>
      <button
        class={`vote-btn upvote ${userVote === 1 ? "active" : ""}`}
        aria-label="Upvote"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"><polyline points="18 15 12 9 6 15"></polyline></svg
        >
      </button>
      <span class="vote-count"
        >{
          post.like_count > 0
            ? post.like_count
            : post.like_count < 0
              ? post.like_count
              : "Vote"
        }</span
      >
      <button
        class={`vote-btn downvote ${userVote === -1 ? "active" : ""}`}
        aria-label="Downvote"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg
        >
      </button>
    </div>

    <a
      href={`/post/${post.id}`}
      class="action-btn"
      style="text-decoration:none;"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
        ></path></svg
      >
      <span class="action-text"
        >{commentCount > 0 ? commentCount : "Comment"}</span
      >
    </a>

    <button class="action-btn share-btn" data-post-id={post.id}>
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"
        ></circle><circle cx="18" cy="19" r="3"></circle><line
          x1="8.59"
          y1="13.51"
          x2="15.42"
          y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"
        ></line></svg
      >
      <span class="action-text">Share</span>
    </button>

    <button
      class={`action-btn save-btn ${isSaved ? "active" : ""}`}
      data-post-id={post.id}
      style={isSaved ? "color: var(--accent)" : ""}
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"
        ></path></svg
      >
    </button>

    {
      post.is_flagged && isAdmin && (
        <span class="flagged-chip ml-auto">⚑ Flagged</span>
      )
    }
  </footer>
</article>

<!-- Edit modal (one per page, JS-controlled) -->
<div id="admin-edit-modal" class="modal-overlay" hidden>
  <div class="modal-box">
    <div class="modal-head">
      <h3 style="font-size:.9375rem;font-weight:600">Edit Post</h3>
      <button id="edit-modal-close" class="btn btn-ghost btn-xs">✕</button>
    </div>
    <textarea
      id="edit-modal-content"
      maxlength="2000"
      rows="5"
      class="input"
      style="resize:none;line-height:1.5;font-size:.875rem"
      placeholder="Post content…"></textarea>
    <div
      style="text-align:right;font-size:.75rem;color:var(--text-3);margin:.25rem 0 1rem"
    >
      <span id="edit-modal-chars">0</span>/2000
    </div>
    <div style="display:flex;justify-content:flex-end;gap:.5rem">
      <button id="edit-modal-cancel" class="btn btn-secondary btn-sm"
        >Cancel</button
      >
      <button id="edit-modal-save" class="btn btn-primary btn-sm">Save</button>
    </div>
  </div>
</div>

<script>
  // Vote toggle logic
  document.querySelectorAll(".vote-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const isUp = btn.classList.contains("upvote");
      const group = btn.closest(".vote-group") as HTMLElement;
      if (!group) return;
      const postId = group.dataset.postId;
      if (!postId) return;

      const upBtn = group.querySelector(".upvote") as HTMLButtonElement;
      const downBtn = group.querySelector(".downvote") as HTMLButtonElement;
      const countSpan = group.querySelector(".vote-count");
      if (!upBtn || !downBtn || !countSpan) return;

      const wasUp = upBtn.classList.contains("active");
      const wasDown = downBtn.classList.contains("active");

      let newValue = 0;
      if (isUp) {
        newValue = wasUp ? 0 : 1;
      } else {
        newValue = wasDown ? 0 : -1;
      }

      upBtn.disabled = true;
      downBtn.disabled = true;
      const res = await fetch("/api/votes", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ postId, value: newValue }),
      });
      upBtn.disabled = false;
      downBtn.disabled = false;
      if (!res.ok) return;

      let diff = 0;
      if (wasUp) diff -= 1;
      if (wasDown) diff += 1;
      if (newValue === 1) diff += 1;
      if (newValue === -1) diff -= 1;

      const nText = countSpan.textContent?.replace("k", "") || "0";
      const currentCount = parseInt(nText === "Vote" ? "0" : nText, 10);
      const updatedCount = currentCount + diff;

      upBtn.classList.toggle("active", newValue === 1);
      downBtn.classList.toggle("active", newValue === -1);
      countSpan.textContent =
        updatedCount === 0 ? "Vote" : String(updatedCount);

      if ((window as any).showToast) {
        if (newValue === 1) (window as any).showToast("Post upvoted");
        else if (newValue === -1) (window as any).showToast("Post downvoted");
        else (window as any).showToast("Vote removed");
      }
    });
  });

  // Share logic
  document.querySelectorAll(".share-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const postId = (btn as HTMLElement).dataset.postId;
      const url = window.location.origin + "/post/" + postId;
      navigator.clipboard.writeText(url).then(() => {
        if ((window as any).showToast)
          (window as any).showToast("Link copied to clipboard!");
        const text = btn.querySelector(".action-text");
        if (text) {
          const old = text.textContent;
          text.textContent = "Copied!";
          setTimeout(() => (text.textContent = old), 2000);
        }
      });
    });
  });

  // Save logic
  document.querySelectorAll(".save-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const postId = (btn as HTMLElement).dataset.postId;
      const res = await fetch("/api/saves", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ postId }),
      });
      if (res.ok) {
        const { saved } = await res.json();
        btn.classList.toggle("active", saved);
        (btn as HTMLElement).style.color = saved ? "var(--accent)" : "";
        if ((window as any).showToast)
          (window as any).showToast(
            saved ? "Post saved to bookmarks" : "Post removed from bookmarks",
          );
      }
    });
  });

  // Follow logic
  document.querySelectorAll(".follow-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const followingId = (btn as HTMLElement).dataset.userId;
      const res = await fetch("/api/follows", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ followingId }),
      });
      if (res.ok) {
        const { following } = await res.json();
        btn.textContent = following ? "Following" : "Follow +";
        if ((window as any).showToast)
          (window as any).showToast(
            following
              ? "You are now following this user"
              : "You unfollowed this user",
          );
      }
    });
  });

  // Admin dropdown
  document.querySelectorAll(".admin-trigger").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const id = (btn as HTMLElement).dataset.postId;
      const dd = document.querySelector(
        `[data-dropdown="${id}"]`,
      ) as HTMLElement;
      if (!dd) return;
      const open = !dd.hidden;
      document
        .querySelectorAll("[data-dropdown]")
        .forEach((d) => ((d as HTMLElement).hidden = true));
      dd.hidden = open;
      btn.setAttribute("aria-expanded", String(!open));
    });
  });

  document.addEventListener("click", () => {
    document
      .querySelectorAll("[data-dropdown]")
      .forEach((d) => ((d as HTMLElement).hidden = true));
  });

  // Actions
  async function adminAction(action: string, postId: string, content?: string) {
    const res = await fetch("/api/posts/action", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ action, postId, content }),
    });
    if (res.ok) window.location.reload();
    else {
      const { error } = await res.json().catch(() => ({ error: "Error" }));
      alert(error);
    }
  }

  let pendingEditId: string | null = null;

  document.querySelectorAll("[data-post-action]").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.stopPropagation();
      const dataset = (btn as HTMLElement).dataset;
      const { postAction, postId, content, flagged } = dataset;

      if (!postAction || !postId) return;

      if (postAction === "edit") {
        pendingEditId = postId;
        const ta = document.getElementById(
          "edit-modal-content",
        ) as HTMLTextAreaElement;
        const chars = document.getElementById("edit-modal-chars");
        if (ta && chars) {
          ta.value = content ?? "";
          chars.textContent = String((content ?? "").length);
          document.getElementById("admin-edit-modal")!.hidden = false;
          ta.focus();
        }
        return;
      }

      if (postAction === "flag") {
        await adminAction(flagged === "true" ? "unflag" : "flag", postId);
        return;
      }

      if (confirm("Delete this post?")) await adminAction(postAction, postId);
    });
  });

  // Edit modal
  const editModal = document.getElementById("admin-edit-modal");
  const editTA = document.getElementById(
    "edit-modal-content",
  ) as HTMLTextAreaElement;
  const editChars = document.getElementById("edit-modal-chars");

  editTA?.addEventListener("input", () => {
    if (editChars && editTA)
      editChars.textContent = String(editTA.value.length);
  });

  const closeEdit = () => {
    if (editModal) editModal.hidden = true;
    pendingEditId = null;
  };
  document
    .getElementById("edit-modal-close")
    ?.addEventListener("click", closeEdit);
  document
    .getElementById("edit-modal-cancel")
    ?.addEventListener("click", closeEdit);
  document
    .getElementById("edit-modal-save")
    ?.addEventListener("click", async () => {
      if (!pendingEditId || !editTA) return;
      const val = editTA.value.trim();
      if (!val) {
        alert("Content cannot be empty.");
        return;
      }
      if (editModal) editModal.hidden = true;
      await adminAction("edit", pendingEditId, val);
    });
</script>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    transition: background var(--ease);
    background: var(--bg);
    margin-bottom: 0.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .post-card.is-flagged {
    border-left: 2px solid #f59e0b;
  }

  .post-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .post-header-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-meta-text {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
  }

  .post-dept {
    font-weight: 600;
    color: var(--text-1);
  }
  .post-username {
    color: var(--text-2);
    text-decoration: none;
  }
  .post-username:hover {
    text-decoration: underline;
  }
  .post-time {
    color: var(--text-3);
  }

  .post-header-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .follow-btn {
    border-radius: 99px;
    padding: 0.25rem 0.75rem;
    font-weight: 600;
  }

  .post-body {
    padding-left: 0;
  }

  .post-content {
    font-size: 0.9375rem;
    color: var(--text-1);
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .post-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .vote-group {
    display: inline-flex;
    align-items: center;
    background: var(--bg-2);
    border-radius: 99px;
    padding: 2px;
  }

  .vote-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-2);
    transition:
      background 0.15s,
      color 0.15s;
  }
  .vote-btn:hover {
    background: var(--border);
  }
  .vote-btn.upvote.active {
    color: var(--accent-2);
  }
  .vote-btn.downvote.active {
    color: var(--accent-2);
  }

  .vote-count {
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0 0.25rem;
    color: var(--text-1);
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--bg-2);
    border: none;
    border-radius: 99px;
    padding: 0.375rem 0.75rem;
    cursor: pointer;
    color: var(--text-2);
    font-size: 0.8125rem;
    font-weight: 600;
    transition: background 0.15s;
  }
  .action-btn:hover {
    background: var(--border);
    color: var(--text-1);
  }

  .flagged-chip {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--amber);
  }

  /* Admin menu */
  .admin-menu {
    position: relative;
  }

  .admin-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-3);
    transition:
      background 0.15s,
      color 0.15s;
  }
  .admin-trigger:hover {
    background: var(--bg-2);
    color: var(--text-2);
  }

  .admin-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border-2);
    border-radius: var(--radius-lg);
    min-width: 175px;
    z-index: 50;
    padding: 0.375rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }
  .admin-dropdown[hidden] {
    display: none;
  }

  .dropdown-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-3);
    padding: 0.375rem 0.625rem 0.25rem;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.4375rem 0.625rem;
    border-radius: var(--radius-sm);
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.8125rem;
    font-family: var(--font);
    color: var(--text-2);
    text-decoration: none;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .dropdown-item:hover {
    background: var(--bg-2);
    color: var(--text-1);
  }
  .dropdown-item.danger {
    color: var(--red);
  }
  .dropdown-item.danger:hover {
    background: var(--red-bg);
  }
  .dropdown-sep {
    height: 1px;
    background: var(--border);
    margin: 0.25rem 0;
  }
  .modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
</style>
