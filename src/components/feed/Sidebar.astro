---
import type { LocalUser } from '../../lib/database.types';
interface Props { activeNav: string; user: LocalUser | null; }
const { activeNav, user } = Astro.props;
---

<div class="sidebar-wrap">
  <div class="sidebar-brand">
    <span class="logo-mark">UP</span>
    <span class="brand-text">UniPulse</span>
  </div>

  <nav class="sidebar-nav">
    <a href="/feed" class={`nav-item ${activeNav === 'feed' ? 'active' : ''}`}>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Feed
    </a>
    <a href="/resources" class={`nav-item ${activeNav === 'resources' ? 'active' : ''}`}>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      Resources
    </a>
    <a href="/news" class={`nav-item ${activeNav === 'news' ? 'active' : ''}`}>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a4 4 0 0 1-4 4z"/><line x1="10" y1="7" x2="18" y2="7"/><line x1="10" y1="11" x2="18" y2="11"/><line x1="10" y1="15" x2="16" y2="15"/></svg>
      Campus News
    </a>
    {user?.role === 'admin' && (
      <a href="/admin" class={`nav-item ${activeNav === 'admin' ? 'active' : ''}`}>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Admin
        <span class="admin-dot"></span>
      </a>
    )}
  </nav>

  <div class="sidebar-bottom">
    {user && (
      <a href={`/profile/${user.username}`} class={`profile-link ${activeNav === 'profile' ? 'active' : ''}`}>
        <div class="avatar avatar-md">
          {user.avatar_url ? <img src={user.avatar_url} alt="" /> : user.username.charAt(0).toUpperCase()}
        </div>
        <div class="profile-info">
          <span class="profile-username">@{user.username}</span>
          <span class="pulse-id">{user.pulse_id}</span>
        </div>
      </a>
    )}
    <a href="/settings" class={`nav-item settings-link ${activeNav === 'settings' ? 'active' : ''}`}>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      Settings
    </a>
    <form action="/api/auth/signout" method="POST">
      <button type="submit" class="signout-btn">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign out
      </button>
    </form>
  </div>
</div>

<style>
  .sidebar-wrap { display:flex;flex-direction:column;height:100%;padding:1.25rem .875rem;gap:.25rem;background:var(--bg); }
  .sidebar-brand { display:flex;align-items:center;gap:.5rem;padding:0 .5rem;margin-bottom:1.25rem; }
  .brand-text { font-size:1rem;font-weight:600;color:var(--text); }
  .sidebar-nav { display:flex;flex-direction:column;gap:2px;flex:1; }
  .admin-dot { width:6px;height:6px;border-radius:50%;background:#f59e0b;margin-left:auto;flex-shrink:0; }
  .sidebar-bottom { display:flex;flex-direction:column;gap:2px;padding-top:.5rem;border-top:1px solid var(--border);margin-top:.5rem; }
  .profile-link { display:flex;align-items:center;gap:.625rem;padding:.5rem .75rem;border-radius:var(--radius-md);text-decoration:none;transition:background var(--ease);margin-bottom:2px; }
  .profile-link:hover,.profile-link.active { background:var(--bg-2); }
  .profile-info { display:flex;flex-direction:column;min-width:0;overflow:hidden; }
  .profile-username { font-size:.875rem;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
  .settings-link { font-size:.8125rem;color:var(--text-2); }
  .signout-btn { display:flex;align-items:center;gap:.75rem;width:100%;padding:.5rem .875rem;border-radius:var(--radius-md);font-family:var(--font);font-size:.875rem;font-weight:500;color:var(--text-3);background:none;border:none;cursor:pointer;transition:background var(--ease),color var(--ease);text-align:left; }
  .signout-btn:hover { background:var(--danger-bg);color:var(--danger-text); }
</style>