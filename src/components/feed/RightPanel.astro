---
import { getEvents, getRegisteredEvents } from "../../lib/db";
import { formatRelativeTime } from "../../lib/utils";

const user = Astro.locals.user!;
const events = getEvents().slice(0, 3);
const reminders = getRegisteredEvents(user.id);
---

<div class="panel-wrap">
  <div class="tabs-header">
    <button class="tab-btn active" data-tab="events">Recent Events</button>
    <button class="tab-btn" data-tab="reminders">Reminders</button>
  </div>

  <div class="tab-content active" id="tab-events">
    <div class="recent-list">
      {events.length === 0 ? (
        <div class="empty-text">No recent events.</div>
      ) : (
        events.map(event => (
          <a href={`/search?q=${encodeURIComponent(event.title)}&tab=events`} class="recent-card">
            <div class="recent-meta">
              <span class="recent-sub">s/events</span>
              <span class="recent-time">{formatRelativeTime(event.event_date)}</span>
            </div>
            <div class="recent-body">
              <div class="recent-content">
                <h4 class="recent-title">{event.title}</h4>
                <span class="recent-link">{event.location}</span>
              </div>
              <div class="recent-thumb" style="background:var(--bg-3); display:flex; align-items:center; justify-content:center; font-size:1.5rem;">📅</div>
            </div>
          </a>
        ))
      )}
    </div>
  </div>

  <div class="tab-content" id="tab-reminders" hidden>
    <div class="recent-list">
      {reminders.length === 0 ? (
        <div class="empty-text">You haven't registered for any events yet.</div>
      ) : (
        reminders.map(rem => (
          <a href={`/events`} class="recent-card">
            <div class="recent-meta">
              <span class="recent-sub">s/events</span>
              <span class="recent-time">{formatRelativeTime(rem.event_date)}</span>
            </div>
            <div class="recent-body">
              <div class="recent-content">
                <h4 class="recent-title">{rem.title}</h4>
                <span class="recent-link">{rem.location}</span>
              </div>
              <div class="recent-thumb" style="background:var(--bg-3); display:flex; align-items:center; justify-content:center; font-size:1.5rem;">📅</div>
            </div>
          </a>
        ))
      )}
    </div>
  </div>

  <div class="panel-card mt-6">
    <h3 class="panel-title" style="margin-bottom:.5rem;">Posting Rules</h3>
    <ul class="rules-list">
      <li>Max <strong>5 posts</strong> per day</li>
      <li><strong>15-min</strong> cooldown between posts</li>
      <li>Resets at <strong>midnight</strong></li>
      <li>Keep it respectful</li>
    </ul>
  </div>

  <p class="panel-footer">UniPulse · Campus Edition</p>
</div>

<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.tab;
      
      // Update buttons
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // Update contents
      document.querySelectorAll('.tab-content').forEach(c => (c as HTMLElement).hidden = true);
      const tab = document.getElementById(`tab-${target}`);
      if (tab) tab.hidden = false;
    });
  });
</script>

<style>
  .panel-wrap {
    display: flex;
    flex-direction: column;
    padding-left: 1rem;
  }
  
  .tabs-header {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  
  .tab-btn {
    background: none;
    border: none;
    padding: 0.5rem 0;
    font-size: .875rem;
    font-weight: 600;
    color: var(--text-2);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  
  .tab-btn:hover {
    color: var(--text-1);
  }
  
  .tab-btn.active {
    color: var(--text-1);
    border-bottom-color: var(--accent);
  }
  
  .empty-text {
    font-size: .875rem;
    color: var(--text-2);
    text-align: center;
    padding: 1rem 0;
  }

  .recent-list { display: flex; flex-direction: column; gap: 1rem; }
  
  .recent-card {
    display: flex;
    flex-direction: column;
    gap: .25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }
  .recent-card:last-child { border-bottom: none; }
  
  .recent-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
  }
  .recent-sub {
    font-size: .75rem;
    font-weight: 500;
    color: var(--text-2);
  }
  .recent-time {
    font-size: .65rem;
    color: var(--accent);
  }
  
  .recent-body {
    display: flex;
    gap: .75rem;
  }
  .recent-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .recent-title {
    font-size: .875rem;
    font-weight: 500;
    color: var(--text-1);
    line-height: 1.3;
  }
  .recent-link {
    font-size: .65rem;
    color: var(--accent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .recent-thumb {
    width: 60px;
    height: 45px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .panel-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1rem;
  }
  .panel-title {
    font-size: .875rem;
    font-weight: 600;
    color: var(--text-1);
  }
  .rules-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .375rem;
  }
  .rules-list li {
    font-size: .75rem;
    color: var(--text-2);
    padding-left: .875rem;
    position: relative;
  }
  .rules-list li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: var(--text-3);
  }
  .rules-list strong {
    color: var(--text-1);
    font-weight: 500;
  }
  .panel-footer {
    font-size: .75rem;
    color: var(--text-3);
    text-align: center;
    margin-top: 1.5rem;
  }
</style>
