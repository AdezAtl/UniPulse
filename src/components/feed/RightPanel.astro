---
import { getNews } from "../../lib/db";
const latest = getNews().slice(0, 3);
---

<div class="panel-wrap">
  <div class="search-wrap">
    <svg
      class="search-icon"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      ><circle cx="11" cy="11" r="8"></circle><line
        x1="21"
        y1="21"
        x2="16.65"
        y2="16.65"></line></svg
    >
    <input
      type="search"
      placeholder="Search UniPulse…"
      class="search-field"
      disabled
      title="Coming soon"
    />
  </div>

  {
    latest.length > 0 && (
      <div class="panel-card">
        <h3 class="panel-title">Campus News</h3>
        <div class="news-list">
          {latest.map((item) => (
            <a href="/news" class="news-item">
              <span class="news-hl">{item.title}</span>
              <span class="news-date">
                {new Date(item.created_at).toLocaleDateString("en-GB", {
                  day: "2-digit",
                  month: "short",
                })}
              </span>
            </a>
          ))}
        </div>
        <a href="/news" class="panel-more">
          View all →
        </a>
      </div>
    )
  }

  <div class="panel-card">
    <h3 class="panel-title">Posting Rules</h3>
    <ul class="rules-list">
      <li>Max <strong>5 posts</strong> per day</li>
      <li><strong>15-min</strong> cooldown between posts</li>
      <li>Resets at <strong>midnight</strong> (your time)</li>
      <li>Keep it respectful</li>
    </ul>
  </div>

  <p class="panel-footer">UniPulse · Campus Edition</p>
</div>
<style>
  .panel-wrap {
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .search-wrap {
    position: relative;
  }
  .search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-3);
    pointer-events: none;
  }
  .search-field {
    width: 100%;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.75rem 0.5rem 2.25rem;
    font-family: var(--font);
    font-size: 0.8125rem;
    color: var(--text);
    outline: none;
    opacity: 0.6;
    cursor: not-allowed;
  }
  .panel-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
  }
  .panel-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.75rem;
  }
  .news-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .news-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.375rem 0.25rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--ease);
  }
  .news-item:hover {
    background: var(--bg-2);
  }
  .news-hl {
    font-size: 0.8125rem;
    color: var(--text-2);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }
  .news-date {
    font-size: 0.75rem;
    color: var(--text-3);
    white-space: nowrap;
  }
  .panel-more {
    display: block;
    margin-top: 0.625rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }
  .panel-more:hover {
    text-decoration: underline;
  }
  .rules-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .rules-list li {
    font-size: 0.75rem;
    color: var(--text-2);
    padding-left: 0.875rem;
    position: relative;
  }
  .rules-list li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: var(--text-3);
  }
  .rules-list strong {
    color: var(--text);
    font-weight: 500;
  }
  .panel-footer {
    font-size: 0.75rem;
    color: var(--text-3);
    text-align: center;
    margin-top: auto;
    padding-top: 0.5rem;
  }
</style>
