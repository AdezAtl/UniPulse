---
import type { User } from "../../lib/db";

interface Props {
  user: User | null;
}
const { user } = Astro.props;
---

<header class="top-header">
  <div class="header-content">
    <div class="header-left">
      <button
        id="mobile-menu-btn"
        class="header-icon-btn mobile-menu-btn"
        aria-label="Toggle menu"
        style="display: none;"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><line x1="3" y1="12" x2="21" y2="12"></line><line
            x1="3"
            y1="6"
            x2="21"
            y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
        >
      </button>
      <a href="/feed" class="logo-wrap">
        <img
          src="/android-chrome-192x192.png"
          alt="UniPulse"
          style="width: 32px; height: 32px; border-radius: 6px;"
        />
        <span class="logo-text">UniPulse</span>
      </a>
    </div>

    <div class="header-center">
      <form action="/search" method="GET" class="search-wrap">
        <svg
          class="search-icon"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          type="search"
          name="q"
          placeholder="Search UniPulse…"
          class="search-field"
        />
      </form>
    </div>

    <div class="header-right">
      <a href="/feed#compose" class="btn btn-primary btn-sm create-btn">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><line x1="12" y1="5" x2="12" y2="19"></line><line
            x1="5"
            y1="12"
            x2="19"
            y2="12"></line></svg
        >
        <span class="create-text">Create</span>
      </a>

      <button
        id="theme-toggle"
        class="header-icon-btn"
        aria-label="Toggle theme"
      >
        <!-- Sun/Moon SVG logic handled in script -->
        <svg
          class="sun-icon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><circle cx="12" cy="12" r="5"></circle><line
            x1="12"
            y1="1"
            x2="12"
            y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line
            x1="4.22"
            y1="4.22"
            x2="5.64"
            y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
          ></line><line x1="1" y1="12" x2="3" y2="12"></line><line
            x1="21"
            y1="12"
            x2="23"
            y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"
          ></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg
        >
        <svg
          class="moon-icon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          style="display:none"
          ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
          ></path></svg
        >
      </button>

      <a href="/messages" class="header-icon-btn" aria-label="Messages">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><path
            d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
          ></path></svg
        >
      </a>

      <a href="/notifications" class="header-icon-btn" aria-label="Notifications">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          ><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path
            d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg
        >
      </a>

      {
        user ? (
          <a href={`/profile/${user.username}`} class="avatar-link">
            <div class="avatar avatar-md">
              {user.avatar_url ? (
                <img src={user.avatar_url} alt="" />
              ) : (
                user.username.charAt(0).toUpperCase()
              )}
            </div>
          </a>
        ) : (
          <a href="/login" class="btn btn-secondary btn-sm">
            Log in
          </a>
        )
      }
    </div>
  </div>
</header>

<script>
  const themeToggle = document.getElementById("theme-toggle");
  const sunIcon = document.querySelector(".sun-icon") as HTMLElement;
  const moonIcon = document.querySelector(".moon-icon") as HTMLElement;

  const updateIcons = () => {
    const isDark = document.documentElement.classList.contains("dark");
    if (sunIcon && moonIcon) {
      sunIcon.style.display = isDark ? "none" : "block";
      moonIcon.style.display = isDark ? "block" : "none";
    }
  };

  updateIcons();

  themeToggle?.addEventListener("click", () => {
    document.documentElement.classList.toggle("dark");
    const isDark = document.documentElement.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateIcons();
  });

  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  mobileMenuBtn?.addEventListener("click", () => {
    document.body.classList.toggle("mobile-sidebar-open");
  });
</script>

<style>
  .top-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    width: 100vw;
    overflow-x: hidden;
  }
  .header-content {
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    padding: 0 1rem;
    gap: 1rem;
  }
  .header-left {
    display: flex;
    align-items: center;
    min-width: max-content;
    gap: 0.5rem;
  }
  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .header-center {
    flex: 1;
    max-width: 600px;
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .search-wrap {
    position: relative;
    width: 100%;
  }
  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-3);
    pointer-events: none;
  }
  .search-field {
    width: 100%;
    background: var(--bg-2);
    border: 1px solid transparent;
    border-radius: 99px;
    padding: 0.5rem 1rem 0.5rem 2.75rem;
    font-family: var(--font);
    font-size: 0.875rem;
    color: var(--text-1);
    outline: none;
    transition:
      background 0.15s,
      border-color 0.15s,
      box-shadow 0.15s;
  }
  .search-field:focus {
    background: var(--bg);
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
  }
  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg-2);
    border: none;
    color: var(--text-1);
    cursor: pointer;
    transition:
      background 0.15s,
      transform 0.1s;
  }
  .header-icon-btn:hover:not(:disabled) {
    background: var(--border);
  }
  .header-icon-btn:active:not(:disabled) {
    transform: scale(0.95);
  }
  .header-icon-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .create-btn {
    border-radius: 99px;
    padding: 0.375rem 0.875rem;
    font-weight: 600;
  }
  .avatar-link {
    display: flex;
    border-radius: 50%;
    transition: box-shadow 0.15s;
  }
  .avatar-link:hover {
    box-shadow: 0 0 0 2px var(--border);
  }

  @media (min-width: 1025px) {
    .header-left {
      min-width: 240px;
    }
  }

  @media (max-width: 768px) {
    .mobile-menu-btn {
      display: flex !important;
      background: transparent;
    }
    .logo-text {
      display: none;
    }
    .create-btn {
      padding: 0.375rem;
      border-radius: 50%;
    }
    .create-btn .create-text {
      display: none;
    } /* Assuming we add a class or just hide text */
    .header-content {
      gap: 0.5rem;
      padding: 0 0.5rem;
    }
    .header-center {
      flex: 0 1 auto;
      min-width: 40px;
    }
    .search-field {
      padding: 0.5rem;
      border-radius: 50%;
      color: transparent;
      cursor: pointer;
    }
    .search-field::placeholder {
      color: transparent;
    }
    .search-icon {
      left: 50%;
      transform: translate(-50%, -50%);
    }
    .search-field:focus {
      width: 200px;
      border-radius: 99px;
      padding: 0.5rem 1rem 0.5rem 2.75rem;
      color: var(--text-1);
      position: absolute;
      right: 0;
      z-index: 60;
    }
    .search-field:focus + .search-icon {
      left: 1rem;
      transform: translateY(-50%);
      z-index: 61;
    }
  }
</style>
