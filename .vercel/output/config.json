{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/content/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/user/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/signout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/likes/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/posts/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/resources/?$",
			"dest": "_render"
		},
		{
			"src": "^/feed/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/news/?$",
			"dest": "_render"
		},
		{
			"src": "^/profile/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/resources/?$",
			"dest": "_render"
		},
		{
			"src": "^/signup/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}