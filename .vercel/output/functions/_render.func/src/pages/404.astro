---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 · UniPulse">
  <div class="not-found">
    <p class="code">404</p>
    <h1 class="title">Page not found</h1>
    <p class="sub">This page doesn't exist or you don't have access to it.</p>
    <a href="/feed" class="btn btn-primary" style="padding:.625rem 1.5rem;border-radius:var(--radius-lg)">Back to Feed</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    text-align: center;
    padding: 2rem;
  }

  .code  { font-size: 5rem; font-weight: 700; color: var(--border-3); line-height: 1; }
  .title { font-size: 1.25rem; font-weight: 600; color: var(--text); }
  .sub   { font-size: .9375rem; color: var(--text-2); margin-bottom: .5rem; }
</style>
