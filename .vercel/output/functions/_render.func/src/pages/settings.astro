---
import AppLayout from '../layouts/AppLayout.astro';

const user = Astro.locals.user!;

const DEPARTMENTS = [
  'Computer Science','Engineering','Medicine','Law','Business',
  'Arts & Humanities','Natural Sciences','Social Sciences','Education','Other',
];
const LEVELS = ['100 Level','200 Level','300 Level','400 Level','500 Level','Postgraduate'];

const success = Astro.url.searchParams.get('success');
---

<AppLayout activeNav="profile" user={user} title="Settings · UniPulse" showRightPanel={false}>

  <div class="page-header">
    <h1 class="page-title">Settings</h1>
  </div>

  <div class="settings-layout">

    <!-- Sidebar nav -->
    <nav class="settings-nav">
      <a href="#profile"  class="settings-link active" data-section="profile">Profile</a>
      <a href="#account"  class="settings-link"        data-section="account">Account</a>
      <a href="#identity" class="settings-link"        data-section="identity">Identity</a>
    </nav>

    <!-- Content -->
    <div class="settings-content">

      {success === 'profile' && (
        <div class="alert alert-success" style="margin-bottom:1.5rem">
          Profile updated successfully.
        </div>
      )}
      {success === 'password' && (
        <div class="alert alert-success" style="margin-bottom:1.5rem">
          Password changed successfully.
        </div>
      )}

      <!-- ── Profile section ─────────────────────────────────────────────── -->
      <section class="settings-section" id="profile">
        <div class="section-header">
          <h2 class="section-title">Profile</h2>
          <p class="muted">Your public-facing information on UniPulse.</p>
        </div>

        <!-- Avatar placeholder -->
        <div class="avatar-row">
          <div class="avatar" style="width:64px;height:64px;font-size:1.5rem;font-weight:600;background:var(--bg-3);color:var(--text-2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0">
            {user.avatar_url
              ? <img src={user.avatar_url} alt="" style="width:100%;height:100%;object-fit:cover;border-radius:50%" />
              : user.username.charAt(0).toUpperCase()
            }
          </div>
          <div>
            <p style="font-size:.875rem;font-weight:500;color:var(--text)">@{user.username}</p>
            <p class="hint">{user.pulse_id}</p>
            <p class="hint" style="margin-top:.25rem">Avatar upload coming soon.</p>
          </div>
        </div>

        <form id="profile-form" class="settings-form">
          <div class="form-row">
            <div>
              <label class="label" for="username">Username</label>
              <input id="username" name="username" type="text" class="input"
                value={user.username} required minlength="3" maxlength="30"
                pattern="[a-zA-Z0-9_]+" autocomplete="username" />
              <p class="hint" style="margin-top:.25rem">Letters, numbers, underscores only.</p>
            </div>
            <div>
              <label class="label" for="full_name">Full Name <span class="muted">(optional)</span></label>
              <input id="full_name" name="full_name" type="text" class="input"
                value={user.full_name ?? ''} maxlength="80" autocomplete="name" />
            </div>
          </div>

          <div class="form-row">
            <div>
              <label class="label" for="department">Department</label>
              <select id="department" name="department" required class="input">
                {DEPARTMENTS.map(d => (
                  <option value={d} selected={d === user.department}>{d}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="label" for="level">Level</label>
              <select id="level" name="level" required class="input">
                {LEVELS.map(l => (
                  <option value={l} selected={l === user.level}>{l}</option>
                ))}
              </select>
            </div>
          </div>

          <div id="profile-error" class="alert alert-danger" hidden></div>

          <div class="form-footer">
            <button type="submit" id="profile-btn" class="btn btn-primary btn-sm">
              Save changes
            </button>
          </div>
        </form>
      </section>

      <hr class="divider" style="margin:2rem 0" />

      <!-- ── Account section ─────────────────────────────────────────────── -->
      <section class="settings-section" id="account">
        <div class="section-header">
          <h2 class="section-title">Account</h2>
          <p class="muted">Manage your login credentials.</p>
        </div>

        <form id="password-form" class="settings-form">
          <div>
            <label class="label" for="current_password">Current Password</label>
            <input id="current_password" name="current_password" type="password"
              class="input" placeholder="••••••••" required autocomplete="current-password" />
          </div>
          <div class="form-row">
            <div>
              <label class="label" for="new_password">New Password</label>
              <input id="new_password" name="new_password" type="password"
                class="input" placeholder="Min. 8 characters" required minlength="8"
                autocomplete="new-password" />
            </div>
            <div>
              <label class="label" for="confirm_password">Confirm New Password</label>
              <input id="confirm_password" name="confirm_password" type="password"
                class="input" placeholder="Repeat new password" required
                autocomplete="new-password" />
            </div>
          </div>

          <div id="password-error" class="alert alert-danger" hidden></div>

          <div class="form-footer">
            <button type="submit" id="password-btn" class="btn btn-primary btn-sm">
              Change password
            </button>
          </div>
        </form>
      </section>

      <hr class="divider" style="margin:2rem 0" />

      <!-- ── Identity section ────────────────────────────────────────────── -->
      <section class="settings-section" id="identity">
        <div class="section-header">
          <h2 class="section-title">Identity</h2>
          <p class="muted">Read-only — these values are permanent.</p>
        </div>

        <div class="identity-grid">
          <div class="identity-item">
            <span class="label" style="margin-bottom:.25rem">Pulse ID</span>
            <div class="identity-value">
              <code class="pulse-id" style="font-size:.875rem;padding:4px 10px">{user.pulse_id}</code>
              <span class="hint">Permanent — cannot be changed</span>
            </div>
          </div>

          <div class="identity-item">
            <span class="label" style="margin-bottom:.25rem">Role</span>
            <div class="identity-value">
              <span class={user.role === 'admin' ? 'badge badge-warn' : 'badge badge-gray'}>
                {user.role === 'admin' ? '◈ Admin' : '◎ User'}
              </span>
            </div>
          </div>

          <div class="identity-item">
            <span class="label" style="margin-bottom:.25rem">Department</span>
            <div class="identity-value">
              <span style="font-size:.9375rem;color:var(--text)">{user.department}</span>
            </div>
          </div>

          <div class="identity-item">
            <span class="label" style="margin-bottom:.25rem">Level</span>
            <div class="identity-value">
              <span style="font-size:.9375rem;color:var(--text)">{user.level}</span>
            </div>
          </div>
        </div>

        <div class="danger-zone">
          <h3 class="danger-title">Danger Zone</h3>
          <div class="danger-row">
            <div>
              <p style="font-size:.875rem;font-weight:500;color:var(--text)">Delete account</p>
              <p class="hint">Permanently remove your account and all your posts.</p>
            </div>
            <button class="btn btn-danger btn-sm" id="delete-account-btn" disabled title="Coming soon">
              Delete account
            </button>
          </div>
        </div>
      </section>

    </div>
  </div>
</AppLayout>

<script>
  // ── Profile form ────────────────────────────────────────────────────────
  document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn  = document.getElementById('profile-btn') as HTMLButtonElement;
    const errBox = document.getElementById('profile-error') as HTMLElement;
    const get = (n: string) => (form.elements.namedItem(n) as HTMLInputElement)?.value.trim();

    errBox.hidden   = true;
    btn.disabled    = true;
    btn.textContent = 'Saving…';

    const res = await fetch('/api/auth/update-profile', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action:     'update_profile',
        username:   get('username'),
        full_name:  get('full_name'),
        department: get('department'),
        level:      get('level'),
      }),
    });

    if (res.ok) {
      window.location.href = '/settings?success=profile';
    } else {
      const { error } = await res.json();
      errBox.textContent = error;
      errBox.hidden      = false;
      btn.disabled       = false;
      btn.textContent    = 'Save changes';
    }
  });

  // ── Password form ────────────────────────────────────────────────────────
  document.getElementById('password-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn  = document.getElementById('password-btn') as HTMLButtonElement;
    const errBox = document.getElementById('password-error') as HTMLElement;
    const get = (n: string) => (form.elements.namedItem(n) as HTMLInputElement)?.value;

    const newPwd     = get('new_password');
    const confirmPwd = get('confirm_password');

    errBox.hidden = true;

    if (newPwd !== confirmPwd) {
      errBox.textContent = 'New passwords do not match.';
      errBox.hidden      = false;
      return;
    }

    btn.disabled    = true;
    btn.textContent = 'Changing…';

    const res = await fetch('/api/auth/update-profile', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action:           'change_password',
        current_password: get('current_password'),
        new_password:     newPwd,
      }),
    });

    if (res.ok) {
      window.location.href = '/settings?success=password';
    } else {
      const { error } = await res.json();
      errBox.textContent = error;
      errBox.hidden      = false;
      btn.disabled       = false;
      btn.textContent    = 'Change password';
    }
  });

  // ── Settings nav smooth scroll ────────────────────────────────────────────
  document.querySelectorAll('.settings-link').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      document.querySelectorAll('.settings-link').forEach(l => l.classList.remove('active'));
      link.classList.add('active');
      const id = (link as HTMLElement).dataset.section;
      document.getElementById(id!)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

<style>
  .settings-layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
    padding: 1.5rem 1.25rem;
    max-width: 820px;
  }

  @media (max-width: 640px) {
    .settings-layout { grid-template-columns: 1fr; }
    .settings-nav    { display: flex; gap: .25rem; border-bottom: 1px solid var(--border); padding-bottom: .75rem; }
  }

  /* ── Settings sidebar nav ─────────────────────────────── */
  .settings-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
    position: sticky;
    top: 80px;
    align-self: start;
  }

  .settings-link {
    display: block;
    padding: .4375rem .75rem;
    border-radius: var(--radius-sm);
    font-size: .875rem;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    transition: background var(--ease), color var(--ease);
  }

  .settings-link:hover  { background: var(--bg-2); color: var(--text); }
  .settings-link.active { background: var(--bg-2); color: var(--text); }

  /* ── Sections ─────────────────────────────────────────── */
  .settings-content { min-width: 0; }

  .settings-section { scroll-margin-top: 80px; }

  .section-header { margin-bottom: 1.25rem; }
  .section-title  { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: .25rem; }

  /* ── Avatar row ───────────────────────────────────────── */
  .avatar-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--bg-2);
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  /* ── Form ─────────────────────────────────────────────── */
  .settings-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 520px) { .form-row { grid-template-columns: 1fr; } }

  .form-footer {
    display: flex;
    justify-content: flex-end;
    padding-top: .25rem;
  }

  /* ── Identity grid ────────────────────────────────────── */
  .identity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 520px) { .identity-grid { grid-template-columns: 1fr; } }

  .identity-item {
    background: var(--bg-2);
    border-radius: var(--radius-md);
    padding: .875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: .375rem;
  }

  .identity-value {
    display: flex;
    align-items: center;
    gap: .625rem;
    flex-wrap: wrap;
  }

  /* ── Danger zone ──────────────────────────────────────── */
  .danger-zone {
    border: 1px solid rgba(185,28,28,.25);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .danger-title {
    font-size: .8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--danger-text);
    padding: .625rem 1rem;
    background: var(--danger-bg);
    border-bottom: 1px solid rgba(185,28,28,.15);
  }

  .danger-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    flex-wrap: wrap;
  }
</style>